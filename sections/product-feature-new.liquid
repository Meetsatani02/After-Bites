{{ 'global.css' | asset_url | stylesheet_tag }}

  <style>
        .product-feature-custom {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 48px;
            position: relative;
        }

        .product-feature-custom-image {
            background-color: #E6DCC2;
            border-radius: 40px;
            position: relative;
        }

        .product-feature-custom-image img {
            width: 100%;
            height: auto;
        }

        .product-feature-logo {
            position: absolute;
            bottom: -6%;
            right: -4%;
        }


        /* old css */

        .product-heading h1,
        .product-heading h2 {
            font-family: 'Rasbern';
            font-weight: 600;
            font-style: SemiBold;
            font-size: 56px;
            line-height: 1.1;
            letter-spacing: 0%;
            color: var(--green);
        }


        .product-review {
            display: flex;
            gap: 12px;
            margin: 16px 0px 20px 0px;
        }

        .pro-review-start {
            gap: 5px;
            display: flex;
        }

        .product-description-content {
            /* max-width: 540px; */
            width: 100%;
        }

        .product-description-content p {
            font-family: 'Inter';
            font-weight: 400;
            font-size: 16px;
            line-height: 1;
            letter-spacing: 0%;
            color: var(--green);
        }

        .product-price {
            margin: 32px 0px 56px 0px;
            display: flex;
            gap: 10px;
        }

        .product-price-main span {
            font-family: 'Rasbern';
            font-weight: 700;
            font-style: Bold;
            font-size: 44px;
            line-height: 1.15;
            letter-spacing: 2%;
            text-transform: uppercase;
            color: var(--green);
        }

        .product-price-compare {
            font-family: 'Rasbern';
            font-weight: 400;
            font-style: Regular;
            font-size: 20px;
            line-height: 1.15;
            letter-spacing: 2%;
            text-transform: uppercase;
            color: #312409;
            display: flex;
            align-items: self-end;
            text-decoration: line-through;
        }

        .product-weight {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .product-weight-text {
            font-family: Inter;
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;

        }

        .product-weight-buttons {
            display: flex;
            gap: 12px;
        }

        .product-weight-buttons span {
            /* font-family: Gilroy-Medium; */
            font-weight: 400;
            font-size: 18px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;
            color: var(--green);
            padding: 10px 26px;
            border: 1px solid var(--green);
            border-radius: 8px;
            cursor: pointer;
        }

        .product-weight-buttons span:hover {
            color: var(--beige);
            background-color: var(--green);
        }

        .product-quantity-cart-button {
            margin-block: 48px;
            display: flex;
            gap: 16px;
        }

        .product-quntity-button-input {
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            border: 1.5px solid #1C3025;
            padding: 14px 20px;
            background-color: var(--beige);
        }

        .product-quntity-button-input .qty-btn {
            border: none;
            background: transparent;
            cursor: pointer;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;

        }

        .product-quntity-button-input .qty-btn img {
            display: block;
            width: 16px;
            height: 16px;
        }

        .product-quntity-button-input .qty-value {
            color: var(--green);

            border: none;
            background: transparent;
            outline: none;
            width: 75px;
            padding: 0;

            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 1.5;
            letter-spacing: -2%;
            text-align: center;
            vertical-align: middle;
        }

        .product-buy-button {
            width: 100%;
        }

        .product-buy-button button {
            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 1.5;
            letter-spacing: -2%;
            vertical-align: middle;
            color: #ffff;
            background-color: var(--green);
            padding-block: 15px;
            border-radius: 12px;
            width: -webkit-fill-available;
        }

    </style>

      <section class="product-feature-custom global_container">

        <div>
            <div class="product-feature-custom-image">
                <img src="/img/product-bg.png" alt="product">
                <div class="product-feature-logo">
                    <img src="/img/gray-logo.svg" alt="logo">
                </div>
            </div>

        </div>
        <div class="product-section-content-custom">
            <div class="product-sec-inner">
                <div class="product-content">
                    <div class="product-heading">
                        <h1>Lorem Ipsum is simply </h1>
                        <!-- <h2>lorem Ipsum is simply</h2> -->
                    </div>
                    <div class="product-review">
                        <div class="pro-review-start">
                            {% render 'start' %}
                            {% render 'start' %}
                            {% render 'start' %}
                            {% render 'start' %}
                            {% render 'start' %}
                        </div>
                        <div class="pro-how-many-review-content">
                            (36 reviews)
                        </div>
                    </div>
                    <div class="product-description-content">
                        <p>
                            Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has
                            been
                            the industry's standard dummy text ever since the 1500s, when an unknown printer took a
                            galley
                            of type and scrambled.
                        </p>
                    </div>
                    <div class="product-price">
                        <div class="product-price-main">
                            <span>₹50.00</span>
                        </div>
                        <div class="product-price-compare">
                            (₹49.00)
                        </div>
                    </div>
                    <div class="product-weight">
                        <span class="product-weight-text">Pack Size/Weight:</span>
                        <div class="product-weight-buttons">
                            <span>50g</span>
                            <span>100g</span>
                            <span>180g</span>
                            <span>200g</span>
                        </div>
                    </div>
                    <div class="product-quantity-cart-button">
                        <div class="product-quntity-button-input">
                            <button type="button" class="qty-btn qty-minus">
                                {% render 'minus' %}
                            </button>
                            <input type="text" class="qty-value" value="01" readonly>
                            <button type="button" class="qty-btn qty-plus">
                                {% render 'plus' %}
                            </button>
                        </div>

                        <div class="product-buy-button">
                            <button>Add to Cart</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
 <script>
        (function () {
            const wrap = document.querySelector('.product-quntity-button-input');
            if (!wrap) return;
            const value = wrap.querySelector('.qty-value');
            const minus = wrap.querySelector('.qty-minus');
            const plus = wrap.querySelector('.qty-plus');
            let qty = 1;

            function render() {
                value.value = String(qty).padStart(2, '0');
            }

            minus.addEventListener('click', function () {
                if (qty > 1) qty--;
                render();
            });

            plus.addEventListener('click', function () {
                qty++;
                render();
            });

            render();
        })();
    </script>

