{{ 'global.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<style>
  .product-feature-custom {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 48px;
      position: relative;
      box-sizing: border-box;
      /* Container gutters — same 1440px-centered alignment as the other
         sections: content stays off the screen edges on every width. */
      padding-left: 40px;
      padding-right: 40px;
  }

  .product-feature-custom-image {
      background-color: #E6DCC2;
      border-radius: 40px;
      position: relative;
  }

  .product-feature-custom-image img {
      width: 100%;
      height: auto;
  }

  .product-feature-logo {
      position: absolute;
      bottom: -6%;
      right: -4%;
  }

  .product-description-content-para p{

}

  /* Stack to a single column on tablet / mobile. */
  @media (max-width: 1024px) {
      .product-feature-custom {
          grid-template-columns: 1fr;
          gap: 32px;
          padding-left: 30px;
          padding-right: 30px;
      }

      .product-feature-logo {
            bottom: -4%;
            right: -4%;
      }
  }

  @media (max-width: 768px) {
      .product-feature-custom {
          padding-left: 20px;
          padding-right: 20px;
      }

      /* Mobile only: shrink the fixed 176px logo SVG to a clean size. */
      .product-feature-logo {
          width: 138px;
          bottom: -16px;
          right: -20px;
      }

      .product-feature-logo svg,
      .product-feature-logo img {
          display: block;
          width: 100%;
          height: auto;
      }
  }

  @media (max-width: 480px) {
      .product-feature-logo {
          {% comment %} width: 80px; {% endcomment %}
          bottom: -34px;
          right: -21px;
      }
  }
</style>

{%- style -%}
  .feature-spacing-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
  }

  @media screen and (min-width: 1025px) {
    .feature-spacing-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  # Use the product chosen in the section settings. If none is chosen and we're
  # on a product page, fall back to that page's product so it still fills in.
  assign selected_product = section.settings.product
  if selected_product != blank
    assign product = selected_product
  endif
-%}

{%- if product != blank -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign product_form_id = 'product-form-' | append: section.id -%}

  <product-info
    id="MainProduct-{{ section.id }}"
    data-section="{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-url="{{ product.url }}"
  >
    <section class="product-feature-custom global_container feature-spacing-{{ section.id }}">
      <div>
        <div class="product-feature-custom-image">
          {%- if section.settings.feature_image != blank -%}
            <img
              src="{{ section.settings.feature_image | image_url: width: 1200 }}"
              alt="{{ section.settings.feature_image.alt | default: product.title | escape }}"
            >
          {%- elsif product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
            >
          {%- else -%}
            <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/product-bg.png?v=1780661393" alt="product">
          {%- endif -%}
          <div class="product-feature-logo">
            {% render 'gray-logo' %}
          </div>
        </div>
      </div>

      <div class="product-section-content-custom">
        <div class="product-sec-inner">
          <div class="product-content-custom">
            {%- comment -%} Title (dynamic) {%- endcomment -%}
            <div class="product-heading">
              <h1>{{ product.title | escape }}</h1>
            </div>

            {%- comment -%}
              Reviews hidden for this section
              <div class="product-review">
                <div class="pro-review-start">
                  {% render 'start' %}
                  {% render 'start' %}
                  {% render 'start' %}
                  {% render 'start' %}
                  {% render 'start' %}
                </div>
                <div class="pro-how-many-review-content">
                  ({{ product.metafields.reviews.rating_count.value | default: 36 }} reviews)
                </div>
              </div>
            {%- endcomment -%}

            {%- comment -%} Description (dynamic) {%- endcomment -%}
            {%- if product.description != blank -%}
              <div class="product-description-content product-description-content-para">
                {{ product.description }}
              </div>
            {%- endif -%}

            {%- comment -%} Price (dynamic; updated on variant change) {%- endcomment -%}
            <div class="product-price" id="price-{{ section.id }}">
              <div class="product-price-main">
                <span data-price-main>{{ current_variant.price | money }}</span>
              </div>
              <div
                class="product-price-compare"
                data-price-compare
                {% unless current_variant.compare_at_price > current_variant.price %}
                  hidden
                {% endunless %}
              >
                {{ current_variant.compare_at_price | money }}
              </div>
            </div>

            {%- comment -%} Variants as the design's weight buttons (dynamic) {%- endcomment -%}
            {%- unless product.has_only_default_variant -%}
              <div class="product-weight" data-variant-picker>
                {%- for option in product.options_with_values -%}
                  <span class="product-weight-text">{{ option.name }}:</span>
                  <div class="product-weight-buttons" data-option-index="{{ forloop.index0 }}">
                    {%- for value in option.values -%}
                      <span
                        class="weight-opt{% if option.selected_value == value %} is-selected{% endif %}"
                        data-value="{{ value | escape }}"
                      >
                        {{- value -}}
                      </span>
                    {%- endfor -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            {%- comment -%} Quantity + working Add to Cart (dynamic) {%- endcomment -%}
            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product',
                product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ current_variant.id }}"
                  class="product-variant-id"
                  data-variant-id-input
                  {% if current_variant.available == false %}
                    disabled
                  {% endif %}
                >

                <div class="product-quantity-cart-button">
                  <div class="product-quntity-button-input">
                    <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">
                      {% render 'minus' %}
                    </button>
                    <input
                      type="text"
                      class="qty-value"
                      name="quantity"
                      value="01"
                      inputmode="numeric"
                      aria-label="Quantity"
                    >
                    <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">
                      {% render 'plus' %}
                    </button>
                  </div>

                  <div class="product-buy-button">
                    <button
                      type="submit"
                      name="add"
                      data-add-button
                      {% if current_variant.available == false or current_variant == null %}
                        disabled
                      {% endif %}
                    >
                      <span data-add-button-text>
                        {%- if current_variant == null -%}
                          Unavailable
                        {%- elsif current_variant.available -%}
                          Add to Cart
                        {%- else -%}
                          Sold out
                        {%- endif -%}
                      </span>
                      {%- comment -%}
                        Empty, permanently-hidden spinner: product-form.js calls
                        .loading__spinner.classList on submit, so the element must
                        exist — but it renders nothing, so no loading icon shows.
                      {%- endcomment -%}
                      <span class="loading__spinner" style="display: none !important;"></span>
                    </button>
                  </div>
                </div>
              {%- endform -%}
            </product-form>

            {%- comment -%}
              Shipping + ingredients hidden for this section
              <div class="product-buy-shipping">
                <div class="product-buy-shipping-inner">
                  <div class="product-buy-shipping-icon-text border-right">
                    <div class="product-icon-text">
                      <div class="product-icon-package-truck">
                        {% render 'shipping' %}
                      </div>
                      <span>Free shipping for <br> orders over $60</span>
                    </div>
                  </div>
                  <div class="product-buy-shipping-icon-text">
                    <div class="product-icon-text">
                      <div class="product-icon-package-truck">
                        {% render 'truck' %}
                      </div>
                      <span>Ships in 1 <br> business day</span>
                    </div>
                  </div>
                </div>
              </div>

                Ingredients / Benefits (hidden)
              {%- assign ingredients_list = product.metafields.custom.ingredients.value -%}
              {%- assign benefits_list = product.metafields.custom.benefits.value -%}
              <div class="product-ingri-dec-toggle">
                <div class="product-ingredients border-bottom">
                  <div class="product-ingrdients-first-inner">
                    <div class="product-ingredients-inner">
                      <p>Ingredients</p>
                      <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.530273 0.530321L6.53032 6.53027L12.5303 0.530273" stroke="#1C3025" stroke-width="1.5" stroke-miterlimit="16" />
                      </svg>
                    </div>
                    <div class="product-ingredients-description">
                      <ul>
                        {%- if ingredients_list != blank -%}
                          {%- for item in ingredients_list -%}
                            <li>{{ item }}</li>
                          {%- endfor -%}
                        {%- else -%}
                          <li>Variyali</li>
                          <li>Dhana</li>
                          <li>Pan</li>
                          <li>Manpasand</li>
                          <li>Navrang</li>
                          <li>Kesri</li>
                          <li>Kharek</li>
                          <li>Lovely</li>
                          <li>Katho</li>
                          <li>Chuno</li>
                          <li>Ijmet</li>
                          <li>Haripatti</li>
                          <li>Cheri</li>
                          <li>Gulkandh</li>
                          <li>Chatney</li>
                        {%- endif -%}
                      </ul>
                    </div>
                  </div>
                </div>
                <div class="product-ingredients border-bottom">
                  <div class="product-ingrdients-first-inner">
                    <div class="product-ingredients-inner">
                      <p>Benifites</p>
                      <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.530273 0.530321L6.53032 6.53027L12.5303 0.530273" stroke="#1C3025" stroke-width="1.5" stroke-miterlimit="16" />
                      </svg>
                    </div>
                    <div class="product-ingredients-description">
                      <ul>
                        {%- if benefits_list != blank -%}
                          {%- for item in benefits_list -%}
                            <li>{{ item }}</li>
                          {%- endfor -%}
                        {%- else -%}
                          <li>Mind & Mood</li>
                          <li>Degestion</li>
                          <li>Body Cooling</li>
                          <li>Mouth & Oral Health</li>
                          <li>Energy & Nutrition</li>
                          <li>Immunity & Antioxidants</li>
                        {%- endif -%}
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            {%- endcomment -%}
          </div>
        </div>
      </div>
    </section>

    {%- comment -%} Variant data for client-side selection {%- endcomment -%}
    <script type="application/json" data-product-variants>
      [
        {%- for v in product.variants -%}
          {
            "id": {{ v.id | json }},
            "options": [
              {{ v.option1 | json }}
              {%- if v.option2 %}, {{ v.option2 | json }}{% endif -%}
              {%- if v.option3 %}, {{ v.option3 | json }}{% endif -%}
            ],
            "available": {{ v.available | json }},
            "price": {{ v.price | money | json }},
            "compare_at_price": {{ v.compare_at_price | money | json }},
            "has_compare": {% if v.compare_at_price > v.price %}true{% else %}false{% endif %},
            "image": {% if v.featured_image %}{{ v.featured_image | image_url: width: 1500 | json }}{% else %}null{% endif %}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    </script>
  </product-info>

  <script>
    (function () {
      var root = document.getElementById('MainProduct-{{ section.id }}');
      if (!root) return;

      /* ---- Quantity stepper ---- */
      var wrap = root.querySelector('.product-quntity-button-input');
      if (wrap) {
        var value = wrap.querySelector('.qty-value');
        var minus = wrap.querySelector('.qty-minus');
        var plus = wrap.querySelector('.qty-plus');
        var qty = 1;
        function renderQty() {
          value.value = String(qty).padStart(2, '0');
        }
        minus.addEventListener('click', function () {
          if (qty > 1) qty--;
          renderQty();
        });
        plus.addEventListener('click', function () {
          qty++;
          renderQty();
        });
        value.addEventListener('change', function () {
          var n = parseInt(value.value, 10);
          qty = isNaN(n) || n < 1 ? 1 : n;
          renderQty();
        });
        renderQty();
      }

      /* ---- Ingredients / benefits accordion ---- */
      root.querySelectorAll('.product-ingri-dec-toggle .product-ingredients').forEach(function (item) {
        var header = item.querySelector('.product-ingredients-inner');
        if (!header) return;
        header.addEventListener('click', function () {
          item.classList.toggle('is-open');
        });
      });

      /* ---- Variant selection ---- */
      var picker = root.querySelector('[data-variant-picker]');
      var variantsScript = root.querySelector('[data-product-variants]');
      if (!picker || !variantsScript) return;

      var variants = [];
      try {
        variants = JSON.parse(variantsScript.textContent) || [];
      } catch (e) {
        variants = [];
      }
      var idInput = root.querySelector('[data-variant-id-input]');
      var priceMain = root.querySelector('[data-price-main]');
      var priceCompare = root.querySelector('[data-price-compare]');
      var addButton = root.querySelector('[data-add-button]');
      var addButtonText = root.querySelector('[data-add-button-text]');

      /* Build current selection from the pre-selected buttons */
      var groups = picker.querySelectorAll('.product-weight-buttons');
      var selected = [];
      groups.forEach(function (group, i) {
        var sel = group.querySelector('.weight-opt.is-selected') || group.querySelector('.weight-opt');
        selected[i] = sel ? sel.getAttribute('data-value') : null;
      });

      /* Find the variant matching a given selection array. Iterate over the
         selection (one entry per option group) so extra/missing entries in a
         variant's options array can never break the match. */
      function findVariantFor(sel) {
        return variants.find(function (v) {
          var opts = v.options || [];
          return sel.every(function (val, i) {
            return opts[i] === val;
          });
        });
      }

      /* Mark each weight option as unavailable when the variant it would
         produce (combined with the other current selections) is sold out or
         does not exist. Skipped entirely if variant data is unavailable, so
         the buttons never all get disabled by accident. */
      function refreshAvailability() {
        if (!variants.length) return;
        groups.forEach(function (group, gIndex) {
          group.querySelectorAll('.weight-opt').forEach(function (opt) {
            var candidate = selected.slice();
            candidate[gIndex] = opt.getAttribute('data-value');
            var v = findVariantFor(candidate);
            var unavailable = !v || !v.available;
            opt.classList.toggle('is-unavailable', unavailable);
          });
        });
      }

      function update() {
        /* No variant data: leave the server-rendered price / button as-is. */
        if (!variants.length) return;

        var variant = findVariantFor(selected);

        if (!variant) {
          if (idInput) idInput.setAttribute('disabled', 'disabled');
          if (addButton) addButton.setAttribute('disabled', 'disabled');
          if (addButtonText) addButtonText.textContent = 'Unavailable';
          return;
        }

        if (idInput) {
          idInput.value = variant.id;
          idInput.removeAttribute('disabled');
        }

        if (priceMain) priceMain.textContent = variant.price;
        if (priceCompare) {
          if (variant.has_compare) {
            priceCompare.textContent = variant.compare_at_price;
            priceCompare.removeAttribute('hidden');
          } else {
            priceCompare.setAttribute('hidden', 'hidden');
          }
        }

        if (addButton && addButtonText) {
          if (variant.available) {
            addButton.removeAttribute('disabled');
            addButton.removeAttribute('aria-disabled');
            addButtonText.textContent = 'Add to Cart';
          } else {
            addButton.setAttribute('disabled', 'disabled');
            addButtonText.textContent = 'Sold out';
          }
        }
      }

      picker.querySelectorAll('.weight-opt').forEach(function (opt) {
        opt.addEventListener('click', function () {
          /* Unavailable weights can't be selected. */
          if (opt.classList.contains('is-unavailable')) return;
          var group = opt.closest('.product-weight-buttons');
          var index = parseInt(group.getAttribute('data-option-index'), 10);
          selected[index] = opt.getAttribute('data-value');
          group.querySelectorAll('.weight-opt').forEach(function (o) {
            o.classList.remove('is-selected');
          });
          opt.classList.add('is-selected');
          refreshAvailability();
          update();
        });
      });

      refreshAvailability();
      update();
    })();
  </script>

{%- else -%}
  <section class="product-feature-custom global_container feature-spacing-{{ section.id }}">
    <p style="padding: 40px 20px; text-align: center; color: var(--green); font-family: 'Inter';">
      Select a product for this section in the theme editor.
    </p>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Product feature new",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature image",
      "info": "Optional. Shown in the image card. If empty, the selected product's image is used."
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Margin bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Margin bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product feature new"
    }
  ]
}
{% endschema %}
