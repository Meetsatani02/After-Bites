
<style>
  .nutrition-section {
    box-sizing: border-box;
    background: var(--beige);
    /* spacing mirrors the live FAQ section (top / bottom) */
    padding-block: 66px 80px;
    padding-inline: 40px;
    overflow: hidden;
  }

  .nutrition-inner {
    box-sizing: border-box;
    width: 100%;
    max-width: 1296px;
    margin: 0 auto;
  }

  .nutrition-heading {
    margin: 0 0 48px 0;
    font-family: 'Rasbern', serif;
    font-weight: 600;
    font-size: 72px;
    line-height: 1.1;
    text-align: center;
    color: var(--green);
  }

  /* bordered panel that holds the whole table */
  .nutrition-box {
    position: relative;
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    border: 1px solid var(--green);
    border-radius: 24px;
    overflow: hidden;
    background: var(--beige);
  }

  .nut-row {
    display: grid;
    /* minmax(0, …fr) lets the tracks shrink so the grid never overflows its box */
    grid-template-columns: minmax(0, 34fr) minmax(0, 66fr);
    align-items: stretch;
  }

  /* horizontal divider between rows (not above the first) */
  .nut-row + .nut-row {
    border-top: 1px solid rgba(28, 48, 37, 0.28);
  }

  .nut-cell {
    box-sizing: border-box;
    padding: 18px 40px;
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    line-height: 26px;
    letter-spacing: 0.01em;
    color: var(--green);
    display: flex;
    align-items: center;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .nut-cell--label {
    font-weight: 500;
  }

  .nut-cell--value {
    font-weight: 400;
    /* vertical divider between the two columns */
    border-left: 1px solid rgba(28, 48, 37, 0.28);
  }

  /* decorative brand seal, faded, tucked into the bottom-right corner */
  .nutrition-stamp {
    position: absolute;
    right: 20px;
    bottom: 14px;
    width: clamp(90px, 10vw, 132px);
    height: auto;
    opacity: 0.7;
    pointer-events: none;
    z-index: 2;
  }

  .nutrition-stamp svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .nutrition-section {
      padding-block: 48px 56px;
      padding-inline: 30px;
    }

    .nutrition-heading {
      margin-bottom: 40px;
      font-size: 52px;
    }

    .nut-cell {
      padding: 16px 28px;
      font-size: 18px;
      line-height: 24px;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .nutrition-section {
      padding-block: 40px 48px;
      padding-inline: 20px;
    }

    .nutrition-heading {
      margin-bottom: 28px;
      font-size: 34px;
    }

    .nutrition-box {
      border-radius: 16px;
    }

    .nut-row {
      grid-template-columns: minmax(0, 42fr) minmax(0, 58fr);
    }

    .nut-cell {
      padding: 14px 16px;
      font-size: 14px;
      line-height: 20px;
    }

    .nutrition-stamp {
      right: 10px;
      bottom: 8px;
      width: 78px;
      opacity: 0.55;
    }
  }
</style>

{%- if section.settings.border_image != blank -%}
  {%- assign border_alt = section.settings.border_image.alt | default: 'border' -%}
  <div class="hero-border">
    {{ section.settings.border_image | image_url: width: 3000 | image_tag: alt: border_alt, widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy' }}
  </div>
{%- endif -%}

<section class="nutrition-section" id="Nutrition-{{ section.id }}">
  <div class="nutrition-inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="nutrition-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="nutrition-box">
      {%- for block in section.blocks -%}
        <div class="nut-row" {{ block.shopify_attributes }}>
          <div class="nut-cell nut-cell--label">
            {{ block.settings.label }}{% if block.settings.label != blank %} :{% endif %}
          </div>
          <div class="nut-cell nut-cell--value">
            {{ block.settings.value }}
          </div>
        </div>
      {%- endfor -%}

      <div class="nutrition-stamp" aria-hidden="true">
        {% render 'gray-logo' %}
      </div>
    </div>
  </div>
</section>

{%- if section.settings.border_image != blank -%}
  {%- assign border_alt = section.settings.border_image.alt | default: 'border' -%}
  <div class="hero-border hero-border--bottom">
    {{ section.settings.border_image | image_url: width: 3000 | image_tag: alt: border_alt, widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy' }}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Nutrition",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional. Leave blank to show only the table."
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border image (top & bottom)",
      "info": "Optional decorative checkered border shown above and below the section."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Lorem Ipsum is simply dummy text"
        },
        {
          "type": "textarea",
          "id": "value",
          "label": "Value",
          "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry."
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Nutrition",
      "blocks": [
        { "type": "row" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
