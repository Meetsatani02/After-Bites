{%- comment -%}
  Modern Shopify-style product image slider built on Swiper.js.
  - Coverflow / overlapping centred cards, soft shadows, rounded corners
  - Autoplay + smooth transitions, pagination dots, mobile-first responsive
  - Slides come from image blocks (if added) or the current product's images
{%- endcomment -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

{%- liquid
  assign bg = section.settings.bg_color
  assign card_bg = section.settings.card_bg
  assign autoplay_ms = section.settings.autoplay_speed | times: 1000
-%}

<style>
  #ProductSliderSection-{{ section.id }} {
    background: {{ bg }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #ProductSliderSection-{{ section.id }} .product_slider__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #ProductSliderSection-{{ section.id }} .product_slider__heading {
    margin: 0 0 48px;
    text-align: center;
    font-family: 'Rasbern', 'Inter', sans-serif;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 600;
    color: {{ section.settings.heading_color }};
  }

  #ProductSliderSection-{{ section.id }} .product_slider__container {
    width: 100%;
    padding: 12px 0 8px;
    overflow: visible;
  }

  #ProductSliderSection-{{ section.id }} .product_slider__slide {
    width: 78%;
    max-width: 300px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 26px;
    background: {{ card_bg }};
    border-radius: 24px;
    box-shadow: 0 22px 55px rgba(28, 48, 37, 0.10);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  #ProductSliderSection-{{ section.id }} .swiper-slide-active.product_slider__slide {
    box-shadow: 0 30px 70px rgba(28, 48, 37, 0.18);
  }

  #ProductSliderSection-{{ section.id }} .product_slider__img {
    display: block;
    width: 100%;
    height: 300px;
    object-fit: contain;
  }

  /* Pagination dots */
  #ProductSliderSection-{{ section.id }} .product_slider__pagination {
    position: static;
    margin-top: 36px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  #ProductSliderSection-{{ section.id }} .product_slider__pagination .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    margin: 0 !important;
    background: {{ section.settings.dot_color }};
    opacity: 0.35;
    border-radius: 50%;
    transition: width 0.3s ease, opacity 0.3s ease, border-radius 0.3s ease;
  }

  #ProductSliderSection-{{ section.id }} .product_slider__pagination .swiper-pagination-bullet-active {
    width: 24px;
    opacity: 1;
    border-radius: 4px;
  }

  /* Mobile-first: scale the cards up at larger breakpoints */
  @media (min-width: 750px) {
    #ProductSliderSection-{{ section.id }} .product_slider__slide {
      max-width: 380px;
      padding: 32px;
    }
    #ProductSliderSection-{{ section.id }} .product_slider__img {
      height: 360px;
    }
  }

  @media (min-width: 1200px) {
    #ProductSliderSection-{{ section.id }} .product_slider__slide {
      max-width: 440px;
      padding: 38px;
    }
    #ProductSliderSection-{{ section.id }} .product_slider__img {
      height: 420px;
    }
  }
</style>

<section id="ProductSliderSection-{{ section.id }}" class="product_slider">
  <div class="product_slider__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="product_slider__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="swiper product_slider__container" id="ProductSlider-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.image != blank -%}
              <div class="swiper-slide product_slider__slide" {{ block.shopify_attributes }}>
                <img
                  class="product_slider__img"
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.image.alt | default: shop.name | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- elsif product != blank and product.images.size > 0 -%}
          {%- for image in product.images -%}
            <div class="swiper-slide product_slider__slide">
              <img
                class="product_slider__img"
                src="{{ image | image_url: width: 900 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..3) -%}
            <div class="swiper-slide product_slider__slide">
              {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'product_slider__img' }}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="swiper-pagination product_slider__pagination"></div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function () {
    function initSlider() {
      if (typeof Swiper === 'undefined') {
        return window.setTimeout(initSlider, 50);
      }

      new Swiper('#ProductSlider-{{ section.id }}', {
        effect: 'coverflow',
        grabCursor: true,
        centeredSlides: true,
        slidesPerView: 'auto',
        loop: true,
        speed: {{ section.settings.transition_speed }},
        spaceBetween: 24,
        coverflowEffect: {
          rotate: 0,
          stretch: 0,
          depth: 130,
          modifier: 2.2,
          scale: 0.86,
          slideShadows: false
        },
        {% if section.settings.autoplay %}
          autoplay: {
            delay: {{ autoplay_ms }},
            disableOnInteraction: false,
            pauseOnMouseEnter: true
          },
        {% endif %}
        pagination: {
          el: '#ProductSlider-{{ section.id }} .product_slider__pagination',
          clickable: true
        }
      });
    }

    initSlider();
  })();
</script>

{% schema %}
{
  "name": "Product slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F2F2F2"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1C3025"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Pagination dot color",
      "default": "#1C3025"
    },
    {
      "type": "header",
      "content": "Slider behavior"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay delay",
      "default": 3
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "label": "Transition speed",
      "default": 700
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product slider",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
