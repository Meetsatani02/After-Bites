
<style>
  /* Inter is loaded once globally in theme.liquid; no per-section import needed */

  .hero-section {
      background-color: var(--beige);
      background-size: auto;
      position: relative;
      overflow: hidden;
      z-index: 0;
  }

  .hero-icon-icon {
      position: absolute;
      left: -7px;
      bottom: -213px;
      z-index: -2;
  }

  .hero-container {
      display: flex;
      justify-content: left;
      align-items: center;
      {% comment %} gap: 40px; {% endcomment %}
      width: 100%;
  }

  /* Image-left variant: flip the row so the image bleeds to the left edge. */
  .hero-container--image-left {
      flex-direction: row-reverse;
  }

  /* Both halves are locked to exactly 50% on every screen — no grow/shrink,
     so the image always takes half the width regardless of viewport size. */
  .hero-content,
  .hero-img {
      flex: 0 0 50%;
      max-width: 50%;
      min-width: 0;
      box-sizing: border-box;
  }

  /* Align the text with the 1440px-centered layout: on wide screens the inner
     padding grows so the text starts at the same edge as the centered
     container, while the image half still bleeds to the screen edge. */
  .hero-content {
      padding-left: max(40px, calc((100vw - 1440px) / 2 + 40px));
      padding-right: 40px;
  }

  /* Image-left variant: text is on the right, so mirror the alignment padding
     to the right edge instead. */
  .hero-container--image-left .hero-content {
      padding-left: 40px;
      padding-right: max(40px, calc((100vw - 1440px) / 2 + 40px));
  }

  .hero-content a {
      padding: 10px 20px;
      border: 1px solid var(--green);
      border-radius: 50px;
      font-family: "Inter", sans-serif;
      font-size: 16px;
      font-weight: 500;
      line-height: 16px;
      color: var(--green);
      letter-spacing: 0.03em;
      display: inline-flex;
  }

  .hero-content h1 {
     max-width: 100%;
    font-size: 72px;
    font-weight: 600;
    line-height: 110%;
    margin: 24px 0 32px 0;
    color: var(--green);
    letter-spacing: 0;
  }

  .hero-content p {
      max-width: 506px;
      font-family: "Inter", sans-serif;
      font-size: 16px;
      font-weight: 400;
          line-height: 1.4;
    letter-spacing: 0;
      color: var(--green);
  }

  .hero-btn a {
      border-radius: 12px;
      background-color: var(--green);
      font-size: 16px;
      font-weight: 400;
      line-height: 1.5em;
      letter-spacing: -0.02em;
      color: var(--beige);
      margin-top: 64px;
  }

  .hero-img picture,
  .hero-img img {
      display: block;
      width: 100%;
      height: auto;
  }

  @media (max-width: 1400px) {
      .hero-img img {
          width: 100%;
          position: static;
      }

      .hero-content h1 {
          font-size: 64px;
          margin: 20px 0 20px 0;
      }

      .hero-btn a {
          margin-top: 50px;
      }
  }

  @media (max-width: 1024px) {
      .hero-container {
          align-items: flex-start;
          background-image: none;
          gap: 32px;
          padding: 0;
      }

      /* Mobile stacking order, controlled independently of the desktop
         left/right choice. "Above text" = image on top, "Below text" =
         image underneath. These override the desktop row-reverse rule. */
      .hero-container--image-mobile-top {
          flex-direction: column-reverse;
      }

      .hero-container--image-mobile-bottom {
          flex-direction: column;
      }

      /* Stacked: each half spans the full width below the breakpoint. */
      .hero-content,
      .hero-img {
          flex: none;
          width: 100%;
          max-width: 100%;
      }

      /* Padding only on the text section; image stays flush. The image-left
         selector is included so the desktop mirror padding can't leak here. */
      .hero-content,
      .hero-container--image-left .hero-content {
          padding: 60px 20px;
      }
  }

  @media (max-width: 768px) {
      .hero-container {
          align-items: center;
          gap: 24px;
      }

      .hero-content,
      .hero-container--image-left .hero-content {
          padding: 10px 20px 40px 20px;
      }

      .hero-content h1 {
          font-size: 40px;
          line-height: 1em;
      }
  }
</style>

{%- comment -%}
  Preload the hero image so the browser starts downloading it immediately,
  in parallel with the CSS, instead of discovering it late. This is the main
  fix for a slow Largest Contentful Paint. The preload scanner picks these up
  right away because the hero is the first section on the page.
{%- endcomment -%}
{%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
  {%- liquid
    assign pl_desktop = section.settings.image | default: section.settings.image_mobile
    assign pl_mobile = section.settings.image_mobile | default: section.settings.image
  -%}
  <link rel="preload" as="image" fetchpriority="high"
    media="(max-width: 768px)"
    href="{{ pl_mobile | image_url: width: 900 }}"
    imagesrcset="{{ pl_mobile | image_url: width: 600 }} 600w, {{ pl_mobile | image_url: width: 900 }} 900w, {{ pl_mobile | image_url: width: 1100 }} 1100w"
    imagesizes="100vw">
  <link rel="preload" as="image" fetchpriority="high"
    media="(min-width: 769px)"
    href="{{ pl_desktop | image_url: width: 1500 }}"
    imagesrcset="{{ pl_desktop | image_url: width: 1000 }} 1000w, {{ pl_desktop | image_url: width: 1500 }} 1500w, {{ pl_desktop | image_url: width: 2000 }} 2000w"
    imagesizes="100vw">
{%- endif -%}

<section class="hero-section">
  <div class="hero-container hero-container--image-{{ section.settings.image_position }} hero-container--image-mobile-{{ section.settings.image_position_mobile }}">
    <div class="hero-content">
      {%- if section.settings.badge_text != blank -%}
        <a href="{{ section.settings.badge_link }}">{{ section.settings.badge_text }}</a>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.icon_image != blank -%}
        <div class="hero-icon-icon">
          {{
            section.settings.icon_image
            | image_url: width: 600
            | image_tag:
              width: section.settings.icon_image.width,
              height: section.settings.icon_image.height,
              alt: section.settings.icon_image.alt
            | default: 'hero icon', loading: 'lazy'
          }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="comman_btn_Main hero-btn">
          <a href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        </div>
      {%- endif -%}
    </div>

    <div class="hero-img">
      {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
        {%- liquid
          assign desktop_image = section.settings.image | default: section.settings.image_mobile
          assign image_height = desktop_image.width | divided_by: desktop_image.aspect_ratio
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 600 }} 600w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w, {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w"
              sizes="100vw"
            >
          {%- endif -%}
          {%- if section.settings.image != blank -%}
            <source
              media="(min-width: 769px)"
              srcset="{{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1500 }} 1500w, {{ section.settings.image | image_url: width: 2000 }} 2000w"
              sizes="100vw"
            >
          {%- endif -%}
          <img
            src="{{ desktop_image | image_url: width: 1500 }}"
            alt="{{ desktop_image.alt | default: section.settings.heading | default: 'After Bites Paan Mukhwas tobacco free mouth freshener' | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ image_height }}"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          >
        </picture>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "20+ experience"
    },
    {
      "type": "url",
      "id": "badge_link",
      "label": "Badge link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "After Bites Paan Mukhwas. The Authentic Taste of Tradition"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "From sweet wet paan mukhwas to crunchy dry paan mukhwas, After Bites brings you the best pan mukhwas 100% tobacco free and made with natural paan leaves, gulkand and fennel for a refreshing taste after every meal."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Experience Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "info": "Choose which side the image appears on (desktop).",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image position (mobile)",
      "info": "On mobile the layout stacks. Choose whether the image sits above or below the text.",
      "options": [
        {
          "value": "top",
          "label": "Above text"
        },
        {
          "value": "bottom",
          "label": "Below text"
        }
      ],
      "default": "top"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Shown on desktop (and on mobile if no mobile image is set)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image (mobile)",
      "info": "Optional. Replaces the hero image on screens 768px and below."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Decorative icon"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
