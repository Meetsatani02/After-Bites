{{ 'global.css' | asset_url | stylesheet_tag }}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');

  .hero-section {
      background-color: var(--beige);
      background-size: auto;
      position: relative;
      overflow: hidden;
      z-index: 0;
  }

  .hero-icon-icon {
      position: absolute;
      left: -7px;
      bottom: -213px;
      z-index: -2;
  }

  .hero-container {
      /* background-image: url("img/hero-bg.png");
      background-position: 3% 100%;
      background-repeat: no-repeat;
      background-size: auto; */
      display: flex;
      justify-content: left;
      align-items: center;
      gap: 20px;
      width: 100%;
  }

  .hero-content {
      /* padding: 110px 0 170px 0px; */
      width: 50%;
  }

  .hero-content a {
      padding: 10px 20px;
      border: 1px solid var(--green);
      border-radius: 50px;
      font-family: "Inter", sans-serif;
      font-size: 16px;
      font-weight: 500;
      line-height: 16px;
      color: var(--green);
      letter-spacing: 0.03em;
      display: inline-flex;
  }

  .hero-content h1 {
      max-width: 610px;
      font-size: 72px;
      font-weight: 600;
      margin: 24px 0 32px 0;
      color: var(--green);
  }

  .hero-content p {
      max-width: 500px;
      font-family: "Inter", sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 16px;
      color: var(--green);
  }

  .hero-btn a {
      border-radius: 12px;
      background-color: var(--green);
      font-size: 16px;
      font-weight: 400;
      line-height: 1.5em;
      letter-spacing: -0.02em;
      color: var(--beige);
      margin-top: 64px;
  }

  .hero-img {
      width: 50%;
  }

  .hero-img img {
      /* position: absolute;
      right: 0;
      top: 0; */
  }

  .hero-img picture,
  .hero-img img {
      display: block;
      width: 100%;
      height: auto;
  }

  @media (max-width: 1400px) {
      .hero-content {
          padding: 0 0 0 40px;
      }

      .hero-img img {
          width: 100%;
          position: static;
      }

      .hero-content h1 {
          font-size: 64px;
          margin: 20px 0 20px 0;
      }

      .hero-btn a {
          margin-top: 50px;
      }
  }

  @media (max-width: 1024px) {
      .hero-container {
          flex-direction: column-reverse;
          align-items: flex-start;
          background-image: none;
      }

      .hero-content {
          width: 100%;
          padding: 0;
      }

      .hero-img {
          width: 100%;
      }

      .hero-img {
          width: auto;
      }
  }

  @media (max-width: 768px) {
      .hero-container {
          align-items: center;
      }

      .hero-content h1 {
          font-size: 54px;
          line-height: 1em;
      }
  }
</style>

<section class="hero-section">
  <div class="hero-container global_container">
    <div class="hero-content">
      {%- if section.settings.badge_text != blank -%}
        <a href="{{ section.settings.badge_link }}">{{ section.settings.badge_text }}</a>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.icon_image != blank -%}
        <div class="hero-icon-icon">
          {{
            section.settings.icon_image
            | image_url: width: 600
            | image_tag:
              width: section.settings.icon_image.width,
              height: section.settings.icon_image.height,
              alt: section.settings.icon_image.alt | default: 'hero icon',
              loading: 'lazy'
          }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="comman_btn_Main hero-btn">
          <a href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        </div>
      {%- endif -%}
    </div>

    <div class="hero-img">
      {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
        {%- liquid
          assign desktop_image = section.settings.image | default: section.settings.image_mobile
          assign image_height = desktop_image.width | divided_by: desktop_image.aspect_ratio
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}"
            >
          {%- endif -%}
          {%- if section.settings.image != blank -%}
            <source
              media="(min-width: 769px)"
              srcset="{{ section.settings.image | image_url: width: 1500 }}"
            >
          {%- endif -%}
          <img
            src="{{ desktop_image | image_url: width: 1500 }}"
            alt="{{ desktop_image.alt | default: 'hero image' | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ image_height }}"
            fetchpriority="high"
          >
        </picture>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "20+ experience"
    },
    {
      "type": "url",
      "id": "badge_link",
      "label": "Badge link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lorem Ipsum is simply dummy text of the printing"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The quality and purity of our product has made us a favorite in kitchens across the country. We're proud to be a trusted choice for healthy and delicious cooking."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Experience Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Shown on desktop (and on mobile if no mobile image is set)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image (mobile)",
      "info": "Optional. Replaces the hero image on screens 768px and below."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Decorative icon"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
