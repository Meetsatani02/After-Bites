{{ 'global.css' | asset_url | stylesheet_tag }}

{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{% comment %} <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"> {% endcomment %}

<style>
          @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap');

          .product-image img {
              width: 100%;
              height: 100%;
              display: block;
              object-fit: contain;
          }

          .product-grid {
              max-width: 1024px;
              margin: auto;
          }

          .product-card {
              text-align: center;
              height: auto;
              border: 2px solid rgba(244, 237, 219, 0.45);
              border-radius: 8px;
              overflow: hidden;
              background: var(--green);
              box-sizing: border-box;
          }

          /* Image panel: full jar on a light beige background. */
          .product-image {
              background: var(--beige);
              display: flex;
              align-items: center;
              justify-content: center;
              {% comment %} padding: 28px; {% endcomment %}
              aspect-ratio: 1 / 1;
          }

          .product-image a {
              display: flex;
              align-items: center;
              justify-content: center;
              width: 100%;
              height: 100%;
          }

          /* Green band with the name + description. */
          .product-content {
              background: var(--green);
              color: var(--beige);
              padding: 22px 18px 26px;
              margin-top: 0;
          }

          .product-content h3 {
              font-family: 'Rasbern', 'Cormorant Garamond', serif;
              font-size: 28px;
              font-weight: 600;
              line-height: 1.1;
              margin-bottom: 8px;
              color: var(--beige);
          }

          .product-content h3 a {
              color: inherit;
              text-decoration: none;
          }

          .product-content p,
          .view-btn {
              font: 400 12px/1.5 "Inter", sans-serif;
              color: var(--beige);
          }

          .product-content p {
              max-width: 280px;
              margin: auto;
          }

          .product-bottom,
          .arrow-group,
          .arrow-btn {
              display: flex;
              align-items: center;
          }

          .product-bottom {
              justify-content: space-between;
              gap: 20px;
              margin-top: 100px;
          }

          .arrow-group {
              gap: 12px;
          }

          .view-btn,
          .arrow-btn {
              border: 1px solid var(--beige);
              border-radius: 12px;
              transition: .3s ease;
          }

          .view-btn {
              display: inline-flex;
              width: fit-content;
              padding: 12px 20px;
              text-decoration: none;
              font-size: 16px;
              font-weight: 500;
          }

          .arrow-btn {
              padding: 12px;
              justify-content: center;
              cursor: pointer;
              user-select: none;
          }

          /* Hover effects */
          .view-btn:hover {
              background: var(--beige);
              color: var(--green);
          }

          .arrow-btn:hover {
              background: var(--beige);
          }

          .arrow-btn:hover img {
              filter: brightness(0) saturate(100%) invert(11%) sepia(18%) saturate(1093%) hue-rotate(86deg) brightness(95%) contrast(88%);
          }

          /* Disabled state for slider arrows (Swiper adds this class automatically) */
          .arrow-btn.is-disabled {
              opacity: .35;
              pointer-events: none;
              cursor: default;
          }

          /* Desktop: no slider — lay slides out as a static grid and hide arrows. */
          @media (min-width:769px) {
              .product-grid.swiper .swiper-wrapper {
                  display: grid;
                  grid-template-columns: repeat({{ section.settings.slides_desktop }}, 1fr);
                  gap: {{ section.settings.space_desktop }}px;
                  transform: none !important;
              }

              .product-grid.swiper .swiper-slide {
                  width: auto !important;
                  height: auto;
                  margin: 0 !important;
              }

              .product-bottom .arrow-group {
                  display: none;
              }
          }

          @media (max-width:768px) {
              .product-content h3 {
                  font-size: 28px;
              }

              .product-bottom {
                  margin-top: 50px;
              }
          }

          @media (max-width:480px) {
              .product-content h3 {
                  font-size: 24px;
              }
          }
</style>

{%- liquid
  assign best_collection = collections[section.settings.collection]
  if best_collection == blank or best_collection.all_products_count == 0
    assign best_collection = collections['best-product']
  endif
  assign product_count = section.blocks.size

  assign enable_loop = section.settings.loop
  if product_count <= section.settings.slides_desktop
    assign enable_loop = false
  endif
-%}

<section class="product-wrapper" id="BestProduct-{{ section.id }}">
  {%- if section.settings.border_image != blank -%}
    <div class="hero-border">
      {{
        section.settings.border_image
        | image_url: width: 3000
        | image_tag: alt: section.settings.border_image.alt
        | default: 'border', widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy'
      }}
    </div>
  {%- endif -%}

  <div class="product-container">
    <div class="product-title">
      <h2>{{ section.settings.background_text | escape }}</h2>
      <h3>{{ section.settings.heading | escape }}</h3>
    </div>

    <div class="product-grid swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- assign block_product = block.settings.product -%}
          <div class="product-card swiper-slide" {{ block.shopify_attributes }}>
            <div class="product-image">
              <a href="{{ block_product.url | default: '#' }}">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 720
                    | image_tag: alt: block.settings.image.alt
                    | default: block_product.title, widths: '180, 360, 540, 720', sizes: '360px', loading: 'lazy'
                  }}
                {%- elsif block_product.featured_image != blank -%}
                  {{
                    block_product.featured_image
                    | image_url: width: 720
                    | image_tag: alt: block_product.featured_image.alt
                    | default: block_product.title, widths: '180, 360, 540, 720', sizes: '360px', loading: 'lazy'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>
            </div>

            <div class="product-content">
              <h3>
                <a href="{{ block_product.url | default: '#' }}">
                  {{- block.settings.title | default: block_product.title | escape -}}
                </a>
              </h3>
              <p>
                {%- if block.settings.description != blank -%}
                  {{ block.settings.description }}
                {%- else -%}
                  {{ block_product.description | strip_html | truncatewords: 20 }}
                {%- endif -%}
              </p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="product-bottom">
      <a href="{{ best_collection.url | default: '#' }}" class="view-btn">
        {{- section.settings.button_label | escape -}}
      </a>

      <div class="arrow-group">
        <div class="arrow-btn" data-prev>
          {% render 'left-slider-arrow' %}
          {% comment %} <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/left.svg?v=1780384654" alt="left-arrow"> {% endcomment %}
        </div>

        <div class="arrow-btn" data-next>
          {% render 'right-slider-arrow' %}
          {% comment %} <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/right.svg?v=1780384660" alt="right-arrow"> {% endcomment %}
        </div>
      </div>
    </div>
  </div>

  {%- if section.settings.border_image != blank -%}
    <div class="hero-border hero-border--bottom">
      {{
        section.settings.border_image
        | image_url: width: 3000
        | image_tag: alt: section.settings.border_image.alt
        | default: 'border', widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy'
      }}
    </div>
  {%- endif -%}
</section>

{{ 'swiper-bundle.min.js' | asset_url | script_tag }}
{% comment %} <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script> {% endcomment %}
<script>
  (function () {
      var root = document.getElementById('BestProduct-{{ section.id }}');
      if (!root || typeof Swiper === 'undefined') return;

      var DESKTOP = 769;
      var swiper = null;

      function syncSlider() {
          // Mobile only: build the slider. Desktop uses the CSS grid.
          if (window.innerWidth < DESKTOP) {
              if (swiper) return;
              swiper = new Swiper(root.querySelector('.swiper'), {
                  slidesPerView: {{ section.settings.slides_mobile }},
                  spaceBetween: {{ section.settings.space_mobile }},
                  loop: {{ enable_loop }},
                  {% if section.settings.autoplay %}
                  autoplay: {
                      delay: {{ section.settings.autoplay_speed | times: 1000 }},
                      disableOnInteraction: false
                  },
                  {% endif %}
                  navigation: {
                      nextEl: root.querySelector('[data-next]'),
                      prevEl: root.querySelector('[data-prev]'),
                      disabledClass: 'is-disabled'
                  }
              });
          } else if (swiper) {
              swiper.destroy(true, true);
              swiper = null;
          }
      }

      syncSlider();
      window.addEventListener('resize', syncSlider);
  })();
</script>

{% schema %}
{
  "name": "Best Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the \"Best Product\" collection."
    },
    {
      "type": "text",
      "id": "background_text",
      "label": "Background text",
      "default": "Afterbites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Best Pan Mukhwas"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Products"
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border image (top & bottom)",
      "info": "Decorative border shown above and below the section."
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides per view (desktop)",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides per view (mobile)",
      "default": 1
    },
    {
      "type": "range",
      "id": "space_desktop",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Space between slides (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "space_mobile",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Space between slides (mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Link comes from this product. Title and description fall back to it when left empty below."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Optional. Leave empty to use the product's featured image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Optional. Leave empty to use the product's title."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Custom description",
          "info": "Optional. Leave empty to use the product's description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Product",
      "blocks": [{ "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
