{{ 'global.css' | asset_url | stylesheet_tag }}

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap');

        .product-wrapper,
        .hero-border {
            background: var(--green);
        }

        .hero-border {
            display: flex;
        }

        
        .product-image img {
            width: 100%;
            display: block;
            border-radius:50%;
                height: fit-content;
    object-fit: cover;
        }

        .hero-border img,{
              width: 100%;
            display: block;
        }

        .product-wrapper {
            position: relative;
            overflow: hidden;
        }

        .product-container {
            max-width: 1440px;
            margin: auto;
            padding: 0 60px 60px 50px;
            position: relative;
            z-index: 2;
        }

        .product-title {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 45px;
            text-align: center;
        }

        .product-title h2 {
            font-size: 195px;
            font-weight: 400;
            line-height: 1.28;
            color: var(--yellow);
            opacity: .1;
        }

        .product-title h3 {
            position: absolute;
            top: 85px;
            font-size: 72px;
            font-weight: 600;
            line-height: 1.1;
            color: var(--beige);
        }

        .product-grid {
            max-width: 896px;
            margin: auto;
            display: flex;
            gap: 40px;
            overflow-x: auto;
            scroll-behavior: smooth;
            scroll-snap-type: x mandatory;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
        }

        .product-grid::-webkit-scrollbar {
            display: none;
        }

        .product-card {
            flex: 0 0 calc(50% - 20px);
            text-align: center;
            scroll-snap-align: start;
        }

        .product-image {
            max-width: 360px;
            margin: auto;
        }

        .product-image img {
            height: 427px;
            object-fit: cover;
        }

        .product-content {
            margin-top: 25px;
        }

        .product-content h3 {
            font-size: 33px;
            font-weight: 600;
            line-height: 1;
            margin-bottom: 6px;
            color: var(--beige);
        }

        .product-content h3 a {
            color: inherit;
            text-decoration: none;
        }

        .product-content p,
        .view-btn {
            font: 400 12px/1.5 "Inter", sans-serif;
            color: var(--beige);
        }

        .product-content p {
            max-width: 280px;
            margin: auto;
        }

        .product-bottom,
        .arrow-group,
        .arrow-btn {
            display: flex;
            align-items: center;
        }

        .product-bottom {
            justify-content: space-between;
            gap: 20px;
            margin-top: 100px;
        }

        .arrow-group {
            gap: 12px;
        }

        .view-btn,
        .arrow-btn {
            border: 1px solid var(--beige);
            border-radius: 12px;
            transition: .3s ease;
        }

        .view-btn {
            display: inline-flex;
            width: fit-content;
            padding: 12px 20px;
            text-decoration: none;
            font-size: 16px;
            font-weight: 500;
        }

        .arrow-btn {
            padding: 12px;
            justify-content: center;
            cursor: pointer;
            user-select: none;
        }

        /* Disabled state for slider arrows (e.g. when there are 2 or fewer products) */
        .arrow-btn.is-disabled {
            opacity: .35;
            pointer-events: none;
            cursor: default;
        }

        @media (max-width:1024px) {
            .product-container {
                padding: 40px 30px;
            }

            .product-title h2 {
                font-size: 160px;
            }

            .product-title h3 {
                top: 70px;
                font-size: 62px;
            }
        }

        @media (max-width:768px) {
            .product-container {
                padding: 30px 20px;
            }

            .product-grid {
                gap: 20px;
            }

            .product-card {
                flex: 0 0 100%;
            }

            .product-title {
                margin-bottom: 20px;
            }

            .product-title h2 {
                font-size: 120px;
            }

            .product-title h3 {
                top: 55px;
                font-size: 42px;
            }

            .product-content h3 {
                font-size: 28px;
            }

            .product-bottom {
                margin-top: 50px;
            }
        }

        @media (max-width:480px) {
            .product-title {
                margin-bottom: 40px;
            }

            .product-title h2 {
                display: none;
            }

            .product-title h3 {
                position: static;
                font-size: 36px;
            }

            .product-content h3 {
                font-size: 24px;
            }
        }
    </style>

    {%- liquid
      assign best_collection = collections[section.settings.collection]
      if best_collection == blank or best_collection.all_products_count == 0
        assign best_collection = collections['best-product']
      endif
      assign product_count = best_collection.all_products_count
      assign disable_arrows = false
      if product_count <= 2
        assign disable_arrows = true
      endif
    -%}

        <section class="product-wrapper" id="BestProduct-{{ section.id }}">

        <div class="hero-border">
            <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/border.png?v=1780384582" alt="border">
        </div>

        <div class="product-container">

            <div class="product-title">
                <h2>{{ section.settings.background_text | escape }}</h2>
                <h3>{{ section.settings.heading | escape }}</h3>
            </div>

            <div class="product-grid">
                {%- for product in best_collection.products -%}
                    <div class="product-card">
                        <div class="product-image">
                            <a href="{{ product.url }}">
                                {%- if product.featured_image != blank -%}
                                    {{
                                        product.featured_image
                                        | image_url: width: 720
                                        | image_tag:
                                            alt: product.featured_image.alt | default: product.title,
                                            widths: '180, 360, 540, 720',
                                            sizes: '360px',
                                            loading: 'lazy'
                                    }}
                                {%- else -%}
                                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {%- endif -%}
                            </a>
                        </div>

                        <div class="product-content">
                            <h3><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
                            <p>{{ product.description | strip_html | truncatewords: 20 }}</p>
                        </div>
                    </div>
                {%- endfor -%}
            </div>

            <div class="product-bottom">

                <a href="{{ best_collection.url | default: '#' }}" class="view-btn">{{ section.settings.button_label | escape }}</a>

                <div class="arrow-group">
                    <div class="arrow-btn{% if disable_arrows %} is-disabled{% endif %}" data-prev>
                        <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/left.svg?v=1780384654" alt="left-arrow">
                    </div>

                    <div class="arrow-btn{% if disable_arrows %} is-disabled{% endif %}" data-next>
                        <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/right.svg?v=1780384660" alt="right-arrow">
                    </div>
                </div>

            </div>

        </div>

        <div class="hero-border">
            <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/border.png?v=1780384582" alt="border">
        </div>

    </section>

    <script>
        (function () {
            var section = document.getElementById('BestProduct-{{ section.id }}');
            if (!section) return;

            var slider = section.querySelector('.product-grid'),
                card = section.querySelector('.product-card'),
                next = section.querySelector('[data-next]'),
                prev = section.querySelector('[data-prev]');

            if (!slider || !card || !next || !prev) return;

            var slideAmount = function () {
                return card.offsetWidth + (window.innerWidth <= 768 ? 20 : 40);
            };

            next.addEventListener('click', function () {
                if (next.classList.contains('is-disabled')) return;
                slider.scrollBy({ left: slideAmount(), behavior: 'smooth' });
            });

            prev.addEventListener('click', function () {
                if (prev.classList.contains('is-disabled')) return;
                slider.scrollBy({ left: -slideAmount(), behavior: 'smooth' });
            });
        })();
    </script>

{% schema %}
{
  "name": "Best Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the \"Best Product\" collection."
    },
    {
      "type": "text",
      "id": "background_text",
      "label": "Background text",
      "default": "Afterbites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our best Product"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Product"
    }
  ],
  "presets": [
    {
      "name": "Best Product"
    }
  ]
}

{% endschema %}
