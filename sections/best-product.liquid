{{ 'global.css' | asset_url | stylesheet_tag }}

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap');

        .product-wrapper,
        .hero-border {
            background: var(--green);
        }

        .hero-border {
            display: flex;
            line-height: 0;
        }

        .hero-border img {
            width: 100%;
            display: block;
        }

        /* Flip the bottom border so it mirrors the top one */
        .hero-border--bottom img {
            transform: scaleY(-1);
        }

        .product-image img {
            width: 100%;
            display: block;
            border-radius: 50%;
            height: 427px;
            object-fit: cover;
        }

        .product-wrapper {
            position: relative;
            overflow: hidden;
        }

        .product-container {
            max-width: 1440px;
            margin: auto;
            padding: 0 60px 60px 50px;
            position: relative;
            z-index: 2;
        }

        .product-title {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 45px;
            text-align: center;
            overflow: hidden;
        }

        .product-title h2 {
            font-size: clamp(64px, 15vw, 195px);
            font-weight: 400;
            line-height: 1.28;
            color: var(--yellow);
            opacity: .1;
            font-family: 'Moena', sans-serif;
            white-space: nowrap;
            margin: 0;
        }

        .product-title h3 {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            font-size: clamp(30px, 7vw, 72px);
            font-weight: 600;
            line-height: 1.1;
            color: var(--beige);
            margin: 0;
            white-space: nowrap;
        }

        .product-grid {
            max-width: 896px;
            margin: auto;
        }

        .product-card {
            text-align: center;
            height: auto;
        }

        .product-image {
            max-width: 360px;
            margin: auto;
        }

        .product-content {
            margin-top: 25px;
        }

        .product-content h3 {
            font-size: 33px;
            font-weight: 600;
            line-height: 1;
            margin-bottom: 6px;
            color: var(--beige);
        }

        .product-content h3 a {
            color: inherit;
            text-decoration: none;
        }

        .product-content p,
        .view-btn {
            font: 400 12px/1.5 "Inter", sans-serif;
            color: var(--beige);
        }

        .product-content p {
            max-width: 280px;
            margin: auto;
        }

        .product-bottom,
        .arrow-group,
        .arrow-btn {
            display: flex;
            align-items: center;
        }

        .product-bottom {
            justify-content: space-between;
            gap: 20px;
            margin-top: 100px;
        }

        .arrow-group {
            gap: 12px;
        }

        .view-btn,
        .arrow-btn {
            border: 1px solid var(--beige);
            border-radius: 12px;
            transition: .3s ease;
        }

        .view-btn {
            display: inline-flex;
            width: fit-content;
            padding: 12px 20px;
            text-decoration: none;
            font-size: 16px;
            font-weight: 500;
        }

        .arrow-btn {
            padding: 12px;
            justify-content: center;
            cursor: pointer;
            user-select: none;
        }

        /* Hover effects */
        .view-btn:hover {
            background: var(--beige);
            color: var(--green);
        }

        .arrow-btn:hover {
            background: var(--beige);
        }

        .arrow-btn:hover img {
            filter: brightness(0) saturate(100%) invert(11%) sepia(18%) saturate(1093%) hue-rotate(86deg) brightness(95%) contrast(88%);
        }

        /* Disabled state for slider arrows (Swiper adds this class automatically) */
        .arrow-btn.is-disabled {
            opacity: .35;
            pointer-events: none;
            cursor: default;
        }

        @media (max-width:1024px) {
            .product-container {
                padding: 40px 30px;
            }
        }

        @media (max-width:768px) {
            .product-container {
                padding: 30px 20px;
            }

            .product-title {
                margin-bottom: 20px;
            }

            .product-content h3 {
                font-size: 28px;
            }

            .product-bottom {
                margin-top: 50px;
            }
        }

        @media (max-width:480px) {
            .product-title {
                margin-bottom: 16px;
            }

            .product-content h3 {
                font-size: 24px;
            }
        }
    </style>

    {%- liquid
      assign best_collection = collections[section.settings.collection]
      if best_collection == blank or best_collection.all_products_count == 0
        assign best_collection = collections['best-product']
      endif
      assign product_count = best_collection.all_products_count

      assign enable_loop = section.settings.loop
      if product_count <= section.settings.slides_desktop
        assign enable_loop = false
      endif
    -%}

        <section class="product-wrapper" id="BestProduct-{{ section.id }}">

        {%- if section.settings.border_image != blank -%}
        <div class="hero-border">
            {{
                section.settings.border_image
                | image_url: width: 3000
                | image_tag:
                    alt: section.settings.border_image.alt | default: 'border',
                    widths: '750, 1100, 1500, 2000, 3000',
                    sizes: '100vw',
                    loading: 'lazy'
            }}
        </div>
        {%- endif -%}

        <div class="product-container">

            <div class="product-title">
                <h2>{{ section.settings.background_text | escape }}</h2>
                <h3>{{ section.settings.heading | escape }}</h3>
            </div>

            <div class="product-grid swiper">
                <div class="swiper-wrapper">
                    {%- for product in best_collection.products -%}
                        <div class="product-card swiper-slide">
                            <div class="product-image">
                                <a href="{{ product.url }}">
                                    {%- if product.featured_image != blank -%}
                                        {{
                                            product.featured_image
                                            | image_url: width: 720
                                            | image_tag:
                                                alt: product.featured_image.alt | default: product.title,
                                                widths: '180, 360, 540, 720',
                                                sizes: '360px',
                                                loading: 'lazy'
                                        }}
                                    {%- else -%}
                                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                    {%- endif -%}
                                </a>
                            </div>

                            <div class="product-content">
                                <h3><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
                                <p>{{ product.description | strip_html | truncatewords: 20 }}</p>
                            </div>
                        </div>
                    {%- endfor -%}
                </div>
            </div>

            <div class="product-bottom">

                <a href="{{ best_collection.url | default: '#' }}" class="view-btn">{{ section.settings.button_label | escape }}</a>

                <div class="arrow-group">
                    <div class="arrow-btn" data-prev>
                        <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/left.svg?v=1780384654" alt="left-arrow">
                    </div>

                    <div class="arrow-btn" data-next>
                        <img src="https://cdn.shopify.com/s/files/1/0742/9839/2711/files/right.svg?v=1780384660" alt="right-arrow">
                    </div>
                </div>

            </div>

        </div>

        {%- if section.settings.border_image != blank -%}
        <div class="hero-border hero-border--bottom">
            {{
                section.settings.border_image
                | image_url: width: 3000
                | image_tag:
                    alt: section.settings.border_image.alt | default: 'border',
                    widths: '750, 1100, 1500, 2000, 3000',
                    sizes: '100vw',
                    loading: 'lazy'
            }}
        </div>
        {%- endif -%}

    </section>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        (function () {
            var root = document.getElementById('BestProduct-{{ section.id }}');
            if (!root || typeof Swiper === 'undefined') return;

            new Swiper(root.querySelector('.swiper'), {
                slidesPerView: {{ section.settings.slides_mobile }},
                spaceBetween: {{ section.settings.space_mobile }},
                loop: {{ enable_loop }},
                {% if section.settings.autoplay %}
                autoplay: {
                    delay: {{ section.settings.autoplay_speed | times: 1000 }},
                    disableOnInteraction: false
                },
                {% endif %}
                navigation: {
                    nextEl: root.querySelector('[data-next]'),
                    prevEl: root.querySelector('[data-prev]'),
                    disabledClass: 'is-disabled'
                },
                breakpoints: {
                    769: {
                        slidesPerView: {{ section.settings.slides_desktop }},
                        spaceBetween: {{ section.settings.space_desktop }}
                    }
                }
            });
        })();
    </script>

{% schema %}
{
  "name": "Best Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select the \"Best Product\" collection."
    },
    {
      "type": "text",
      "id": "background_text",
      "label": "Background text",
      "default": "Afterbites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our best Product"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Product"
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border image (top & bottom)",
      "info": "Decorative border shown above and below the section."
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides per view (desktop)",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides per view (mobile)",
      "default": 1
    },
    {
      "type": "range",
      "id": "space_desktop",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Space between slides (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "space_mobile",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Space between slides (mobile)",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Best Product"
    }
  ]
}

{% endschema %}
