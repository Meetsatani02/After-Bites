        <!-- photos -->
        {%- if section.settings.photo_wedding != blank -%}
          <div class="pv-item pv-photo pv-photo--wedding">
            {{
              section.settings.photo_wedding
              | image_url: width: 600
              | image_tag: alt: 'Wedding mandap', widths: '180, 360, 600', loading: 'lazy'
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.photo_car != blank -%}
          <div class="pv-item pv-photo pv-photo--car">
            {{
              section.settings.photo_car
              | image_url: width: 600
              | image_tag: alt: 'Premium car interior', widths: '180, 360, 600', loading: 'lazy'
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.photo_couple != blank -%}
          <div class="pv-item pv-photo pv-photo--couple">
            {{
              section.settings.photo_couple
              | image_url: width: 600
              | image_tag: alt: 'Couple', widths: '180, 360, 600', loading: 'lazy'
            }}
          </div>
        {%- endif -%}

        <!-- sticky notes -->
        <div class="pv-item pv-note pv-note--top">
          <div class="pv-pin">
            {{ section.settings.note_top_pin }}
          </div>
          <!-- <img class="pv-pin" src="img/pin.svg" alt=""> -->
          <p>
            {{ section.settings.note_top_text }}
          </p>
        </div>

        <div class="pv-item pv-note pv-note--mid-left">
          <div class="pv-pin">
            {{ section.settings.note_mid_pin }}
          </div>

          <p>
            {{ section.settings.note_mid_text }}
          </p>
        </div>

        <div class="pv-item pv-note pv-note--center">
          <div class="pv-pin">
            {{ section.settings.note_center_pin }}
          </div>
          <!-- <img class="pv-pin" src="img/pin.svg" alt=""> -->
          <p>
            {{ section.settings.note_center_text }}
          </p>
        </div>
      </div>
    </div>
  </div>

  {%- if section.settings.border_image != blank -%}
    <div class="hero-border hero-border--bottom">
      {{
        section.settings.border_image
        | image_url: width: 3000
        | image_tag: alt: section.settings.border_image.alt
        | default: 'border', widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy'
      }}
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var box = document.querySelector('.pv-main-box-inner');
    if (!box) return;

    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // No animation for reduced-motion users — leave the layout static & visible.
    if (reduceMotion) return;

    var items = Array.prototype.slice.call(box.querySelectorAll('.pv-item'));

    // 1) Staggered scroll-reveal: arm hidden state, then reveal when in view.
    box.classList.add('pv-animate');

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              box.classList.add('is-visible');
              io.disconnect();
            }
          });
        },
        { threshold: 0.2 }
      );
      io.observe(box);
    } else {
      box.classList.add('is-visible'); // fallback: just show it
    }

    // 2) Subtle scroll-linked parallax: items drift at different depths.
    var ticking = false;
    function update() {
      ticking = false;
      var rect = box.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      // progress ~ -0.6..0.6 as the panel's center crosses the viewport center
      var progress = (rect.top + rect.height / 2 - vh / 2) / vh;
      progress = Math.max(-0.6, Math.min(0.6, progress));
      for (var i = 0; i < items.length; i++) {
        var depth = parseFloat(getComputedStyle(items[i]).getPropertyValue('--depth')) || 0;
        items[i].style.setProperty('--pv-px', (progress * depth).toFixed(1) + 'px');
      }
    }
    function onScroll() {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(update);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>

