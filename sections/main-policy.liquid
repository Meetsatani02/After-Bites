{%- comment -%}
  Styles for this section live in assets/base.css (loaded globally),
  under "Legal policy pages". Used by templates/policy.json for all
  four legal policies (Privacy, Refund, Shipping, Terms of Service).
{%- endcomment -%}
<section class="policy-page">
  <div class="policy-page__inner">
    <h1 class="policy-page__title">{{ policy.title }}</h1>
    <hr class="policy-page__divider">

    <div class="policy-rte rte">
      {{ policy.body }}
    </div>

    {%- if section.settings.show_buttons -%}
      <div class="policy-actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="policy-btn policy-btn--primary" href="{{ routes.root_url }}">
            {{ section.settings.primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.contact_label != blank -%}
          <a class="policy-btn policy-btn--ghost" href="{{ section.settings.contact_url | default: '/pages/contact' }}">
            {{ section.settings.contact_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Policy page",
  "settings": [
    {
      "type": "header",
      "content": "Action buttons"
    },
    {
      "type": "checkbox",
      "id": "show_buttons",
      "label": "Show buttons at the bottom",
      "default": true
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Back to Home"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Secondary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Secondary button link",
      "info": "Defaults to your Contact page."
    }
  ]
}
{% endschema %}
