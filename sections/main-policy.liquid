{{ 'global.css' | asset_url | stylesheet_tag }}

<style>
  .policy-page {
    background-color: var(--beige);
    color: var(--green);
    /* extra top so the title clears the header + the logo that dips down */
    padding: clamp(88px, 12vw, 170px) 20px clamp(72px, 9vw, 130px);
  }

  .policy-page__inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .policy-page__title {
    font-family: 'Rasbern', 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1.1;
    text-transform: capitalize;
    color: var(--green);
    margin: 0;
  }

  .policy-page__divider {
    height: 2px;
    border: 0;
    background-color: var(--green);
    opacity: 0.18;
    margin: 18px 0 36px;
  }

  /* policy body (Shopify policy.body) */
  .policy-rte {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: var(--green);
  }

  .policy-rte h2,
  .policy-rte .policy__heading {
    font-family: 'Rasbern', 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.25;
    color: var(--green);
    margin: 52px 0 14px;
  }

  /* first heading/paragraph shouldn't carry the big top gap */
  .policy-rte > :first-child {
    margin-top: 0;
  }

  .policy-rte h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 18px;
    color: var(--green);
    margin: 26px 0 10px;
  }

  .policy-rte p,
  .policy-rte .policy__text,
  .policy-rte .policy__lead {
    margin: 0 0 16px;
  }

  .policy-rte .policy__lead {
    font-size: 17px;
  }

  .policy-rte ul,
  .policy-rte ol,
  .policy-rte .policy__list {
    margin: 0 0 18px;
    padding-left: 22px;
  }

  .policy-rte li,
  .policy-rte .policy__item {
    margin: 0 0 8px;
  }

  .policy-rte a {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .policy-rte strong {
    font-weight: 600;
  }

  /* action buttons */
  .policy-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 48px;
  }

  .policy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 34px;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .policy-btn--primary {
    background-color: var(--green);
    color: var(--beige);
    border: 1.5px solid var(--green);
  }

  .policy-btn--primary:hover {
    transform: translateY(-2px);
  }

  .policy-btn--ghost {
    background-color: transparent;
    color: var(--green);
    border: 1.5px solid var(--green);
  }

  .policy-btn--ghost:hover {
    background-color: var(--green);
    color: var(--beige);
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .policy-actions {
      flex-direction: column;
    }

    .policy-btn {
      width: 100%;
    }
  }
</style>

<section class="policy-page">
  <div class="policy-page__inner">
    <h1 class="policy-page__title">{{ policy.title }}</h1>
    <hr class="policy-page__divider">

    <div class="policy-rte rte">
      {{ policy.body }}
    </div>

    {%- if section.settings.show_buttons -%}
      <div class="policy-actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="policy-btn policy-btn--primary" href="{{ routes.root_url }}">
            {{ section.settings.primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.contact_label != blank -%}
          <a class="policy-btn policy-btn--ghost" href="{{ section.settings.contact_url | default: '/pages/contact' }}">
            {{ section.settings.contact_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Policy page",
  "settings": [
    {
      "type": "header",
      "content": "Action buttons"
    },
    {
      "type": "checkbox",
      "id": "show_buttons",
      "label": "Show buttons at the bottom",
      "default": true
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Back to Home"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Secondary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Secondary button link",
      "info": "Defaults to your Contact page."
    }
  ]
}
{% endschema %}
