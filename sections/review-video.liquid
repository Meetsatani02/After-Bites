{{ 'global.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
      .product-container-video-review{
          max-width: 1440px;
  margin: auto;
  padding: 0 60px 32px 50px;
  position: relative;
  z-index: 2;
      }

      .customer-review-section-main{
          padding-block : 42px;
      }

      .customer-review-section {
          background-color: var(--green);
          {% comment %} padding-block: 64px 72px; {% endcomment %}
          overflow: hidden;
      }



      /* ---------- Swiper ---------- */
      .review-swiper {
          width: 100%;
          padding-block: 64px;
          overflow: visible;
      }

      .review-swiper .swiper-slide {
          width: 268.51px;
          transition: transform 0.45s ease;
          display: flex;
          justify-content: center;
      }

      /* active scales 268.51x352 -> 357x468 (1.33x) */
      .review-swiper .swiper-slide-active {
          transform: scale(1.33);
          z-index: 3;
      }

      .review-video-oval {
          position: relative;
          width: 100%;
          aspect-ratio: 268.51 / 352;
          border-radius: 50%;
          overflow: hidden;
          border: 2px solid rgba(244, 237, 219, 0.85);
          background-color: #000;
      }

      .review-video-oval video {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
      }

      /* play / unmute overlay — only on active slide while muted */
      .review-play-btn {
          position: absolute;
          inset: 0;
          display: none;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          background: rgba(0, 0, 0, 0.12);
          border: none;
          padding: 0;
      }

      .review-play-btn img {
          width: 44px;
          height: 44px;
      }

      .swiper-slide-active .review-play-btn {
          display: flex;
      }

      .swiper-slide-active.is-unmuted .review-play-btn {
          display: none;
      }

      /* mute / unmute speaker icon — only on the active (main) video */
      .review-mute-btn {
          position: absolute;
          left: 50%;
          bottom: 12%;
          transform: translateX(-50%);
          width: 40px;
          height: 40px;
          border-radius: 50%;
          border: none;
          background: rgba(28, 48, 37, 0.55);
          display: none;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          padding: 0;
          z-index: 4;
      }

      .swiper-slide-active .review-mute-btn {
          display: flex;
      }

      .review-mute-btn svg {
          width: 20px;
          height: 20px;
      }

      /* default = muted (show the slashed speaker) */
      .review-mute-btn .icon-on {
          display: none;
      }

      .swiper-slide-active.is-unmuted .review-mute-btn .icon-off {
          display: none;
      }

      .swiper-slide-active.is-unmuted .review-mute-btn .icon-on {
          display: block;
      }

      /* ---------- Bottom controls (arrows + caption) ---------- */
      .review-controls {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 62px;
          max-width: 1100px;
          margin: 40px auto 0;
          padding-inline: 20px;
      }

      .review-arrow {
          flex-shrink: 0;
          width: 44px;
          height: 44px;
          border: 1px solid rgba(244, 237, 219, 0.6);
          border-radius: 12px;
          background: transparent;
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: background-color 0.25s ease, opacity 0.25s ease;
      }

      .review-arrow:hover {
          background-color: rgba(244, 237, 219, 0.12);
      }

      .review-arrow img {
          width: 16px;
          height: 16px;
      }

      .review-arrow.swiper-button-disabled {
          opacity: 0.4;
          cursor: default;
      }

      .review-caption {
          flex: 0 1 auto;
          max-width: 835px;
          text-align: center;
          font-family: 'Inter';
          font-weight: 400;
          font-size: 16px;
          line-height: 1.6;
          color: var(--beige);
          transition: opacity 0.3s ease;
      }

      /* ---------- Responsive ---------- */
      @media (max-width: 1024px) {

          .review-swiper {
              padding-block: 48px;
          }

          .review-swiper .swiper-slide {
              width: 200px;
          }
      }

      @media (max-width: 600px) {
          {% comment %} .customer-review-section {
              padding-block: 44px 52px;
          } {% endcomment %}

          .review-swiper {
              padding-block: 36px;
          }

          .review-swiper .swiper-slide {
              width: 160px;
          }

          .review-swiper .swiper-slide-active {
              transform: scale(1.3);
          }

          .review-controls {
              gap: 14px;
              margin-top: 28px;
              padding-inline: 20px;
          }

          .review-arrow {
              width: 38px;
              height: 38px;
          }

          .review-caption {
              font-size: 14px;
          }
      }
</style>

<section class="product-wrapper customer-review-section-main" id="ReviewVideo-{{ section.id }}">
  <div class="product-container-video-review">
    <div class="product-title">
      <h2>{{ section.settings.background_text | escape }}</h2>
      <h3>{{ section.settings.heading | escape }}</h3>
    </div>
  </div>
  <div class="customer-review-section">
    <div class="customer-swiperslider-video-text">
      <div class="swiper review-swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide" data-caption="{{ block.settings.caption | escape }}" {{ block.shopify_attributes }}>
              <div class="review-video-oval">
                {%- if block.settings.video != blank -%}
                  <video muted autoplay loop playsinline preload="auto">
                    {%- for source in block.settings.video.sources -%}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {%- endfor -%}
                  </video>
                {%- elsif block.settings.video_url != blank -%}
                  <video src="{{ block.settings.video_url }}" muted autoplay loop playsinline preload="auto"></video>
                {%- endif -%}
                <button class="review-play-btn" type="button" aria-label="Toggle sound">
                  {% render 'play-button' %}
                </button>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="review-controls">
        <button class="review-arrow review-prev" type="button" aria-label="Previous">
          {% render 'slider-left-arrow' %}
        </button>

        <p class="review-caption"></p>

        <button class="review-arrow review-next" type="button" aria-label="Next">
          {% render 'slider-right-arrow' %}
        </button>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function () {
    var root = document.getElementById('ReviewVideo-{{ section.id }}');
    if (!root) return;

    function init() {
      if (typeof Swiper === 'undefined') { return window.setTimeout(init, 60); }

      var captionEl = root.querySelector('.review-caption');
      var swiperEl = root.querySelector('.review-swiper');
      var wrapper = swiperEl ? swiperEl.querySelector('.swiper-wrapper') : null;
      if (!swiperEl || !wrapper || !wrapper.children.length) return;

      // duplicate the slides until there are enough to fill the centered loop on
      // wide screens (works for any number of blocks; guard prevents infinite loop)
      var slideHTML = wrapper.innerHTML;
      var dupGuard = 0;
      while (wrapper.children.length < 14 && dupGuard < 14) {
        wrapper.insertAdjacentHTML('beforeend', slideHTML);
        dupGuard++;
      }

      // add a mute/unmute speaker icon to every video (shows only on the active one)
      var muteBtnHTML =
        '<button class="review-mute-btn" type="button" aria-label="Toggle sound">' +
        '<svg class="icon-off" viewBox="0 0 24 24" fill="none" stroke="#F4EDDB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M11 5 6 9H2v6h4l5 4z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>' +
        '</svg>' +
        '<svg class="icon-on" viewBox="0 0 24 24" fill="none" stroke="#F4EDDB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M11 5 6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/>' +
        '</svg>' +
        '</button>';
      wrapper.querySelectorAll('.review-video-oval').forEach(function (oval) {
        oval.insertAdjacentHTML('beforeend', muteBtnHTML);
      });

      var swiper = new Swiper(swiperEl, {
        loop: true,
        loopAdditionalSlides: 4,
        centeredSlides: true,
        slidesPerView: 'auto',
        spaceBetween: 80,
        speed: {{ section.settings.transition_speed }},
        grabCursor: true,
        watchSlidesProgress: true,
        breakpoints: {
          0: { spaceBetween: 28 },
          601: { spaceBetween: 48 },
          1025: { spaceBetween: 80 }
        },
        {% if section.settings.autoplay %}autoplay: { delay: {{ section.settings.autoplay_speed | times: 1000 }}, disableOnInteraction: false },{% endif %}
        navigation: {
          nextEl: root.querySelector('.review-next'),
          prevEl: root.querySelector('.review-prev')
        }
      });

      // fix Swiper's empty side on first load (loop clones aren't positioned
      // until an update with loop + centeredSlides + slidesPerView:'auto')
      requestAnimationFrame(function () {
        swiper.loopFix();
        swiper.update();
      });

      function muteAll() {
        swiperEl.querySelectorAll('video').forEach(function (v) { v.muted = true; });
        swiperEl.querySelectorAll('.swiper-slide').forEach(function (s) { s.classList.remove('is-unmuted'); });
      }

      function updateCaption() {
        var active = swiper.slides[swiper.activeIndex];
        if (!active || !captionEl) return;
        captionEl.style.opacity = 0;
        window.setTimeout(function () {
          captionEl.textContent = active.getAttribute('data-caption') || '';
          captionEl.style.opacity = 1;
        }, 150);
      }

      function updatePlayback() {
        swiperEl.querySelectorAll('.swiper-slide').forEach(function (s) {
          var v = s.querySelector('video');
          if (!v) return;
          if (s.classList.contains('swiper-slide-visible')) {
            var p = v.play();
            if (p && p.catch) p.catch(function () {});
          } else {
            v.pause();
          }
        });
      }

      swiper.on('slideChange', function () {
        muteAll();
        {% if section.settings.autoplay %}if (swiper.autoplay) swiper.autoplay.start();{% endif %}
        updateCaption();
      });

      swiper.on('slideChangeTransitionEnd', updatePlayback);

      swiperEl.addEventListener('click', function (e) {
        var slide = e.target.closest('.swiper-slide');
        if (!slide || !slide.classList.contains('swiper-slide-active')) return;
        var video = slide.querySelector('video');
        if (!video) return;
        if (video.muted) {
          muteAll();
          video.muted = false;
          video.play();
          slide.classList.add('is-unmuted');
          {% if section.settings.autoplay %}if (swiper.autoplay) swiper.autoplay.stop();{% endif %}
        } else {
          video.muted = true;
          slide.classList.remove('is-unmuted');
          {% if section.settings.autoplay %}if (swiper.autoplay) swiper.autoplay.start();{% endif %}
        }
      });

      updateCaption();
      updatePlayback();
    }

    init();
  })();
</script>

{% schema %}
{
  "name": "Review Video",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Review Video"
    },
    {
      "type": "text",
      "id": "background_text",
      "label": "Background text",
      "default": "Reviews"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay delay",
      "default": 4
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "label": "Transition speed",
      "default": 800
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Or video URL",
          "info": "Direct .mp4 / .mov URL — used only if no Video file is selected."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Video",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "video_url": "https://cdn.shopify.com/videos/c/o/v/d49e6b5bcd434c5db48393df3f6711ea.mov",
            "caption": "The quality and purity of our product has made us a favorite in kitchens across the country."
          }
        },
        {
          "type": "review",
          "settings": {
            "video_url": "https://cdn.shopify.com/videos/c/o/v/d49e6b5bcd434c5db48393df3f6711ea.mov",
            "caption": "Our customers love how fresh and authentic every single bite tastes."
          }
        },
        {
          "type": "review",
          "settings": {
            "video_url": "https://cdn.shopify.com/videos/c/o/v/d49e6b5bcd434c5db48393df3f6711ea.mov",
            "caption": "From everyday meals to special occasions, this has become an essential part of my family's kitchen."
          }
        }
      ]
    }
  ]
}
{% endschema %}
