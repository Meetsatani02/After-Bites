  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        (function () {
            const captionEl = document.querySelector('.review-caption');

            // duplicate the slides so the centered loop always stays filled on wide screens
            const wrapper = document.querySelector('.review-swiper .swiper-wrapper');
            wrapper.insertAdjacentHTML('beforeend', wrapper.innerHTML);

            // add a mute/unmute speaker icon to every video (shows only on the active one)
            const muteBtnHTML =
                '<button class="review-mute-btn" type="button" aria-label="Toggle sound">' +
                '<svg class="icon-off" viewBox="0 0 24 24" fill="none" stroke="#F4EDDB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<path d="M11 5 6 9H2v6h4l5 4z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>' +
                '</svg>' +
                '<svg class="icon-on" viewBox="0 0 24 24" fill="none" stroke="#F4EDDB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<path d="M11 5 6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/>' +
                '</svg>' +
                '</button>';
            wrapper.querySelectorAll('.review-video-oval').forEach(function (oval) {
                oval.insertAdjacentHTML('beforeend', muteBtnHTML);
            });

            const swiper = new Swiper('.review-swiper', {
                loop: true,
                loopAdditionalSlides: 4,
                centeredSlides: true,
                slidesPerView: 'auto',
                spaceBetween: 80,
                speed: 800,
                grabCursor: true,
                watchSlidesProgress: true,
                breakpoints: {
                    0: { spaceBetween: 28 },
                    601: { spaceBetween: 48 },
                    1025: { spaceBetween: 80 },
                },
                // continuous right-to-left auto scroll
                autoplay: {
                    delay: 3500,
                    disableOnInteraction: false,
                },
                navigation: {
                    nextEl: '.review-next',
                    prevEl: '.review-prev',
                },
            });

            // fix Swiper's empty left side on first load (loop clones aren't prepended
            // until the first interaction with loop + centeredSlides + slidesPerView:'auto')
            requestAnimationFrame(function () {
                swiper.loopFix();
                swiper.update();
            });

            // mute every video and clear the "unmuted" marker
            function muteAll() {
                document.querySelectorAll('.review-swiper video').forEach(function (v) {
                    v.muted = true;
                });
                document.querySelectorAll('.review-swiper .swiper-slide').forEach(function (s) {
                    s.classList.remove('is-unmuted');
                });
            }

            // update caption text from the active slide
            function updateCaption() {
                const active = swiper.slides[swiper.activeIndex];
                if (!active) return;
                captionEl.style.opacity = 0;
                window.setTimeout(function () {
                    captionEl.textContent = active.getAttribute('data-caption') || '';
                    captionEl.style.opacity = 1;
                }, 150);
            }

            // play only the videos currently in view, pause the rest (saves bandwidth -> no stutter)
            function updatePlayback() {
                document.querySelectorAll('.review-swiper .swiper-slide').forEach(function (s) {
                    const v = s.querySelector('video');
                    if (!v) return;
                    if (s.classList.contains('swiper-slide-visible')) {
                        const p = v.play();
                        if (p && p.catch) p.catch(function () { });
                    } else {
                        v.pause();
                    }
                });
            }

            // when the active slide changes: mute everything, resume autoplay, refresh caption
            swiper.on('slideChange', function () {
                muteAll();
                swiper.autoplay.start();
                updateCaption();
            });

            // manage which videos are playing once each transition settles
            swiper.on('slideChangeTransitionEnd', updatePlayback);

            // click the active video (or its play button) to toggle its sound.
            // delegated so every duplicated / cloned slide responds too.
            const swiperEl = document.querySelector('.review-swiper');
            swiperEl.addEventListener('click', function (e) {
                const slide = e.target.closest('.swiper-slide');
                if (!slide || !slide.classList.contains('swiper-slide-active')) return;

                const video = slide.querySelector('video');
                if (!video) return;

                if (video.muted) {
                    muteAll();              // ensure only this one has sound
                    video.muted = false;
                    video.play();
                    slide.classList.add('is-unmuted');
                    swiper.autoplay.stop();  // pause scrolling while listening
                } else {
                    video.muted = true;
                    slide.classList.remove('is-unmuted');
                    swiper.autoplay.start();
                }
            });

            // initial caption + playback state
            updateCaption();
            updatePlayback();
        })();
    </script>

