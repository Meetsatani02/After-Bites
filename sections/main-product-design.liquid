
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<style>
  body {
      background-color: var(--beige);
  }

  /* Add to Cart loading feedback — spinner shows, label hides while adding */
  .product-buy-button button { position: relative; }
  .product-buy-button button .loading__spinner { display: none; }
  .product-buy-button button.loading .loading__spinner {
      display: inline-flex;
      align-items: center;
      justify-content: center;
  }
  .product-buy-button button.loading [data-add-button-text] { visibility: hidden; }
  .product-buy-button button .loading__spinner svg { width: 24px; height: 24px; }
  .product-buy-button button .loading__spinner .path { stroke: currentColor; }

  /* ===========================================================
     Judge.me — match the After Bites brand palette
     green #1C3025 · beige #F4EDDB · gold #CAA36C
     =========================================================== */

  /* Preview badge (stars + count next to the title) */
  .product-review .jdgm-prev-badge__stars { color: var(--yellow); }
  .product-review .jdgm-prev-badge__text { color: var(--green); font-family: "Inter", sans-serif; }
</style>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  if current_variant.featured_media
    assign main_media = current_variant.featured_media
  else
    assign main_media = product.featured_media
  endif
-%}

<product-info
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-url="{{ product.url }}"
>
  <section id="product-slider-main-product" class="product-new-section">
    <div class="product-new-container product-new-container--image-{{ section.settings.image_position }} product-new-container--image-mobile-{{ section.settings.image_position_mobile }}">
      <div class="product-new-content">
        <div class="product-section">
          <div class="product-sec-inner">
            <div class="product-content-custom">

              {%- comment -%} Breadcrumbs (with BreadcrumbList schema) {%- endcomment -%}
              {% render 'breadcrumbs' %}

              {%- comment -%} Title (dynamic) {%- endcomment -%}
              <div class="product-heading">
                <h1>{{ product.title | escape }}</h1>
              </div>

              {%- comment -%} Reviews — Judge.me preview badge (real rating + count) {%- endcomment -%}
              <div class="product-review">
                <!-- Start of Judge.me code -->
                <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
                  {{ product.metafields.judgeme.badge }}
                </div>
                <!-- End of Judge.me code -->
              </div>

              {%- comment -%} Description (dynamic) {%- endcomment -%}
              {%- if product.description != blank -%}
                <div class="product-description-content">
                  {{ product.description }}
                </div>
              {%- endif -%}

              {%- comment -%} Price (dynamic; updated on variant change) {%- endcomment -%}
              <div class="product-price" id="price-{{ section.id }}">
                <div class="product-price-main">
                  <span data-price-main>{{ current_variant.price | money }}</span>
                </div>
                <div
                  class="product-price-compare"
                  data-price-compare
                  {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}
                >
                  {{ current_variant.compare_at_price | money }}
                </div>
                {%- liquid
                  assign save_pct = 0
                  if current_variant.compare_at_price > current_variant.price
                    assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round
                  endif
                -%}
                <span
                  class="product-price-save"
                  data-price-save
                  {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}
                >Save {{ save_pct }}%</span>
              </div>

              {%- comment -%} Variants as the design's weight buttons (dynamic) {%- endcomment -%}
              {%- unless product.has_only_default_variant -%}
                <div class="product-weight" data-variant-picker>
                  {%- for option in product.options_with_values -%}
                    <span class="product-weight-text">{{ option.name }}:</span>
                    <div class="product-weight-buttons" data-option-index="{{ forloop.index0 }}">
                      {%- for value in option.values -%}
                        <span
                          class="weight-opt{% if option.selected_value == value %} is-selected{% endif %}"
                          data-value="{{ value | escape }}"
                        >{{ value }}</span>
                      {%- endfor -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endunless -%}

              {%- comment -%} Quantity + working Add to Cart (dynamic) {%- endcomment -%}
              <product-form class="product-form" data-section-id="{{ section.id }}">
                <div class="product-form__error-message-wrapper" role="alert" hidden>
                  <span class="product-form__error-message"></span>
                </div>

                {%- form 'product',
                  product,
                  id: product_form_id,
                  class: 'form',
                  novalidate: 'novalidate',
                  data-type: 'add-to-cart-form'
                -%}
                  <input
                    type="hidden"
                    name="id"
                    value="{{ current_variant.id }}"
                    class="product-variant-id"
                    data-variant-id-input
                    {% if current_variant.available == false %}disabled{% endif %}
                  >

                  <div class="product-quantity-cart-button">
                    <div class="product-quntity-button-input">
                      <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">
                        {% render 'minus' %}
                      </button>
                      <input
                        type="text"
                        class="qty-value"
                        name="quantity"
                        value="01"
                        inputmode="numeric"
                        aria-label="Quantity"
                      >
                      <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">
                        {% render 'plus' %}
                      </button>
                    </div>

                    <div class="product-buy-button">
                      <button
                        type="submit"
                        name="add"
                        data-add-button
                        {% if current_variant.available == false or current_variant == null %}disabled{% endif %}
                      >
                        <span data-add-button-text>
                          {%- if current_variant == null -%}
                            Unavailable
                          {%- elsif current_variant.available -%}
                            Add to Cart
                          {%- else -%}
                            Sold out
                          {%- endif -%}
                        </span>
                        {%- comment -%}
                          Loading spinner — shown the instant the button is clicked
                          (product-form.js removes .hidden on submit, re-adds on
                          finish) so Add to Cart feels responsive during the request.
                        {%- endcomment -%}
                        <span class="loading__spinner hidden">
                          {{- 'loading-spinner.svg' | inline_asset_content -}}
                        </span>
                      </button>
                    </div>
                  </div>
                {%- endform -%}
              </product-form>

              {%- comment -%} Shipping info (static design) {%- endcomment -%}
              <div class="product-buy-shipping">
                <div class="product-buy-shipping-inner">
                  <div class="product-buy-shipping-icon-text border-right">
                    <div class="product-icon-text">
                      <div class="product-icon-package-truck">
                        {% render 'shipping' %}
                      </div>
                      <span>Free shipping for <br> orders over $60</span>
                    </div>
                  </div>
                  <div class="product-buy-shipping-icon-text">
                    <div class="product-icon-text">
                      <div class="product-icon-package-truck">
                        {% render 'truck' %}
                      </div>
                      <span>Ships in 1 <br> business day</span>
                    </div>
                  </div>
                </div>
              </div>

              {%- comment -%}
                Ingredients / Benefits — driven by the product metafields
                custom.ingredients and custom.benefits (editable in the product
                admin). Falls back to the demo list if a product has none set.
              {%- endcomment -%}
              {%- assign ingredients_list = product.metafields.custom.ingredients.value -%}
              {%- assign benefits_list = product.metafields.custom.benefits.value -%}
              <div class="product-ingri-dec-toggle">
                <div class="product-ingredients border-bottom">
                  <div class="product-ingrdients-first-inner">
                    <div class="product-ingredients-inner">
                      <p>Ingredients</p>
                      <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.530273 0.530321L6.53032 6.53027L12.5303 0.530273" stroke="#1C3025" stroke-width="1.5" stroke-miterlimit="16" />
                      </svg>
                    </div>
                    <div class="product-ingredients-description">
                      <ul>
                        {%- if ingredients_list != blank -%}
                          {%- for item in ingredients_list -%}
                            <li>{{ item }}</li>
                          {%- endfor -%}
                        {%- else -%}
                          <li>Variyali</li>
                          <li>Dhana</li>
                          <li>Pan</li>
                          <li>Manpasand</li>
                          <li>Navrang</li>
                          <li>Kesri</li>
                          <li>Kharek</li>
                          <li>Lovely</li>
                          <li>Katho</li>
                          <li>Chuno</li>
                          <li>Ijmet</li>
                          <li>Haripatti</li>
                          <li>Cheri</li>
                          <li>Gulkandh</li>
                          <li>Chatney</li>
                        {%- endif -%}
                      </ul>
                    </div>
                  </div>
                </div>
                <div class="product-ingredients border-bottom">
                  <div class="product-ingrdients-first-inner">
                    <div class="product-ingredients-inner">
                      <p>Benifites</p>
                      <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.530273 0.530321L6.53032 6.53027L12.5303 0.530273" stroke="#1C3025" stroke-width="1.5" stroke-miterlimit="16" />
                      </svg>
                    </div>
                    <div class="product-ingredients-description">
                      <ul>
                        {%- if benefits_list != blank -%}
                          {%- for item in benefits_list -%}
                            <li>{{ item }}</li>
                          {%- endfor -%}
                        {%- else -%}
                          <li>Mind & Mood</li>
                          <li>Degestion</li>
                          <li>Body Cooling</li>
                          <li>Mouth & Oral Health</li>
                          <li>Energy & Nutrition</li>
                          <li>Immunity & Antioxidants</li>
                        {%- endif -%}
                      </ul>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

      {%- comment -%}
        Desktop: stacked sticky slide-over (each slide pins, next covers it).
        Mobile (<=1024px): Swiper thumbs gallery — large main image + a synced
        thumbnail strip below. Swiper classes are added by JS only on mobile, so
        they never affect the desktop stack. Tap the main image to zoom.
      {%- endcomment -%}
      <div class="product-new-img">
        {%- comment -%} Main image slider (also the desktop scroll-stack) {%- endcomment -%}
        <div class="product-new-img__main" data-img-main>
          <div class="product-new-img__main-wrapper" data-img-main-wrapper>
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                {%- if media.media_type == 'image' -%}
                  <div class="product-new-img__slide" data-img-slide>
                    <img
                      class="product-new-img__item"
                      src="{{ media | image_url: width: 1500 }}"
                      data-zoom-src="{{ media | image_url: width: 2048 }}"
                      alt="{{ media.alt | default: product.title | escape }}"
                      width="{{ media.preview_image.width }}"
                      height="{{ media.preview_image.height }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      {% if forloop.first %}data-product-image fetchpriority="high"{% endif %}
                    >
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              <div class="product-new-img__slide" data-img-slide>
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          <button class="product-new-img__arrow product-new-img__arrow--prev" type="button" data-img-prev aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="product-new-img__arrow product-new-img__arrow--next" type="button" data-img-next aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        {%- comment -%} Thumbnail strip — mobile only, synced to the main slider {%- endcomment -%}
        {%- if product.media.size > 1 -%}
          <div class="product-new-img__thumbs" data-img-thumbs aria-hidden="true">
            <div class="product-new-img__thumbs-wrapper" data-img-thumbs-wrapper>
              {%- for media in product.media -%}
                {%- if media.media_type == 'image' -%}
                  <div class="product-new-img__thumb" data-img-thumb>
                    <img
                      src="{{ media | image_url: width: 300 }}"
                      alt="{{ media.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="{{ media.preview_image.width }}"
                      height="{{ media.preview_image.height }}"
                    >
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} Fullscreen zoom modal — opened by tapping any image {%- endcomment -%}
  <div class="product-zoom" data-zoom hidden>
    <button class="product-zoom__close" type="button" data-zoom-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button class="product-zoom__nav product-zoom__nav--prev" type="button" data-zoom-prev aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <img
      class="product-zoom__img"
      data-zoom-img
      src="{{ main_media | image_url: width: 2048 }}"
      alt="{{ main_media.alt | default: product.title | escape }}"
      width="{{ main_media.preview_image.width }}"
      height="{{ main_media.preview_image.height }}"
      loading="lazy"
      decoding="async"
    >
    <button class="product-zoom__nav product-zoom__nav--next" type="button" data-zoom-next aria-label="Next">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  {%- comment -%} Variant data for client-side selection {%- endcomment -%}
  <script type="application/json" data-product-variants>
    [
      {%- for v in product.variants -%}
        {
          "id": {{ v.id | json }},
          "options": [
            {{ v.option1 | json }}
            {%- if v.option2 %}, {{ v.option2 | json }}{% endif -%}
            {%- if v.option3 %}, {{ v.option3 | json }}{% endif -%}
          ],
          "available": {{ v.available | json }},
          "price": {{ v.price | money | json }},
          "compare_at_price": {{ v.compare_at_price | money | json }},
          "has_compare": {% if v.compare_at_price > v.price %}true{% else %}false{% endif %},
          "save": {% if v.compare_at_price > v.price %}{{ v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round }}{% else %}0{% endif %},
          "image": {% if v.featured_image %}{{ v.featured_image | image_url: width: 1500 | json }}{% else %}null{% endif %}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>

  {%- comment -%}
    Product structured data WITH aggregateRating.
    Shopify's `product | structured_data` omits ratings, and Judge.me only
    emits loose microdata that isn't attached to the Product — so Google saw
    no product rating. We build a single, connected Product entity here using
    the reviews.rating / reviews.rating_count metafields Judge.me populates.
  {%- endcomment -%}
  {%- liquid
    assign jm_rating = product.metafields.reviews.rating.value
    assign jm_rating_count = product.metafields.reviews.rating_count.value
    assign low_price = product.price_min | money_without_currency | strip_html | replace: ',', ''
    assign high_price = product.price_max | money_without_currency | strip_html | replace: ',', ''
    assign first_variant = product.selected_or_first_available_variant

    # Nutrition / product-details rows for structured data.
    # Same source + "Label | Value" format the Nutrition section renders,
    # exposed to Google as Product.additionalProperty (PropertyValue).
    assign pd_raw = product.metafields.custom.product_details.value | default: '' | strip
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {%- if product.images.size > 0 %}
    "image": [
      {%- for image in product.images limit: 3 -%}
        {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ],
    {%- endif %}
    {%- if product.description != blank %}
    "description": {{ product.description | strip_html | truncate: 320 | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "category": {{ product.type | default: 'Paan Mukhwas / Mouth Freshener' | json }},
    {%- if first_variant.sku != blank %}
    "sku": {{ first_variant.sku | json }},
    {%- endif %}
    {%- if jm_rating_count and jm_rating_count > 0 %}
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ jm_rating.rating }}",
      "reviewCount": "{{ jm_rating_count }}",
      "bestRating": "{{ jm_rating.scale_max | default: 5 }}",
      "worstRating": "{{ jm_rating.scale_min | default: 1 }}"
    },
    {%- endif %}
    {%- if pd_raw != blank %}
    "additionalProperty": [
      {%- assign pd_lines = pd_raw | newline_to_br | split: '<br />' -%}
      {%- assign pd_first = true -%}
      {%- for line in pd_lines -%}
        {%- assign pd_row = line | strip -%}
        {%- if pd_row == blank -%}{%- continue -%}{%- endif -%}
        {%- if pd_row contains '|' -%}{%- assign pd_sep = '|' -%}{%- else -%}{%- assign pd_sep = ':' -%}{%- endif -%}
        {%- assign pd_parts = pd_row | split: pd_sep -%}
        {%- assign pd_raw_label = pd_parts | first -%}
        {%- assign pd_label = pd_raw_label | strip -%}
        {%- assign pd_offset = pd_raw_label.size | plus: 1 -%}
        {%- assign pd_value = pd_row | slice: pd_offset, pd_row.size | strip -%}
        {%- if pd_value == blank -%}{%- continue -%}{%- endif -%}
        {%- unless pd_first -%},{%- endunless -%}
        { "@type": "PropertyValue", "name": {{ pd_label | json }}, "value": {{ pd_value | json }} }
        {%- assign pd_first = false -%}
      {%- endfor -%}
    ],
    {%- endif %}
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "lowPrice": "{{ low_price }}",
      "highPrice": "{{ high_price }}",
      "offerCount": {{ product.variants.size }},
      "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
      "url": {{ request.origin | append: product.url | json }}{% if section.settings.ship_show %},
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "{{ section.settings.ship_rate | default: 0 }}",
          "currency": {{ cart.currency.iso_code | json }}
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": {{ section.settings.ship_country | default: 'IN' | json }}
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": {{ section.settings.ship_handling_min | default: 1 }},
            "maxValue": {{ section.settings.ship_handling_max | default: 2 }},
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": {{ section.settings.ship_transit_min | default: 3 }},
            "maxValue": {{ section.settings.ship_transit_max | default: 7 }},
            "unitCode": "DAY"
          }
        }
      }{% endif %}
    }
  }
  </script>
</product-info>

<script>
  (function () {
    var root = document.getElementById('MainProduct-{{ section.id }}');
    if (!root) return;

    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---- Entrance animations: staggered fade-up on details, fade-in on image ---- */
    if (!reducedMotion) {
      var content = root.querySelector('.product-content-custom');
      if (content) {
        content.classList.add('pn-stagger');
        var kids = Array.prototype.slice.call(content.children);
        var revealKids = function () {
          kids.forEach(function (kid, i) {
            kid.style.animationDelay = (i * 0.08) + 's';
            kid.classList.add('pn-in');
          });
        };
        if ('IntersectionObserver' in window) {
          var contentObserver = new IntersectionObserver(function (entries, obs) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) { revealKids(); obs.disconnect(); }
            });
          }, { threshold: 0.12 });
          contentObserver.observe(content);
        } else {
          revealKids();
        }
      }

      var imgWrap = root.querySelector('.product-new-img');
      if (imgWrap) imgWrap.classList.add('pn-fade');
    }

    /* ---- Quantity stepper ---- */
    var wrap = root.querySelector('.product-quntity-button-input');
    if (wrap) {
      var value = wrap.querySelector('.qty-value');
      var minus = wrap.querySelector('.qty-minus');
      var plus = wrap.querySelector('.qty-plus');
      var qty = 1;
      function renderQty() { value.value = String(qty).padStart(2, '0'); }
      minus.addEventListener('click', function () { if (qty > 1) qty--; renderQty(); });
      plus.addEventListener('click', function () { qty++; renderQty(); });
      value.addEventListener('change', function () {
        var n = parseInt(value.value, 10);
        qty = isNaN(n) || n < 1 ? 1 : n;
        renderQty();
      });
      renderQty();
    }

    /* ---- Ingredients / benefits accordion ---- */
    root.querySelectorAll('.product-ingri-dec-toggle .product-ingredients').forEach(function (item) {
      var header = item.querySelector('.product-ingredients-inner');
      if (!header) return;
      header.addEventListener('click', function () { item.classList.toggle('is-open'); });
    });

    /* ---- Image gallery: tap-to-zoom + Swiper thumbs gallery on mobile ---- */
    var imgMain = root.querySelector('[data-img-main]');
    var slides = imgMain
      ? Array.prototype.slice.call(imgMain.querySelectorAll('.product-new-img__item'))
      : [];

    /* Tap-to-zoom fullscreen modal (works on every screen size) */
    var zoom = root.querySelector('[data-zoom]');
    if (zoom && slides.length) {
      var zoomImg = zoom.querySelector('[data-zoom-img]');
      var zoomSrcs = slides.map(function (s) { return s.getAttribute('data-zoom-src') || s.src; });
      var zoomIndex = 0;
      var zShow = function (i) {
        zoomIndex = (i + zoomSrcs.length) % zoomSrcs.length;
        zoomImg.src = zoomSrcs[zoomIndex];
      };
      var zOpen = function (i) {
        zShow(i);
        zoom.removeAttribute('hidden');
        document.documentElement.style.overflow = 'hidden';
      };
      var zClose = function () {
        zoom.setAttribute('hidden', 'hidden');
        document.documentElement.style.overflow = '';
      };
      slides.forEach(function (s, i) {
        s.addEventListener('click', function () { zOpen(i); });
      });
      zoom.querySelector('[data-zoom-close]').addEventListener('click', zClose);
      zoom.querySelector('[data-zoom-prev]').addEventListener('click', function () { zShow(zoomIndex - 1); });
      zoom.querySelector('[data-zoom-next]').addEventListener('click', function () { zShow(zoomIndex + 1); });
      zoom.addEventListener('click', function (e) { if (e.target === zoom) zClose(); });
      document.addEventListener('keydown', function (e) {
        if (zoom.hasAttribute('hidden')) return;
        if (e.key === 'Escape') zClose();
        if (e.key === 'ArrowLeft') zShow(zoomIndex - 1);
        if (e.key === 'ArrowRight') zShow(zoomIndex + 1);
      });
    }

    /* Swiper thumbs gallery on <=1024px; desktop keeps the scroll-stack.
       Swiper classes are added/removed by breakpoint so they never affect the
       desktop sticky stack. */
    var imgMainWrapper = root.querySelector('[data-img-main-wrapper]');
    var mainSlides = imgMain
      ? Array.prototype.slice.call(imgMain.querySelectorAll('[data-img-slide]'))
      : [];
    var imgThumbs = root.querySelector('[data-img-thumbs]');
    var imgThumbsWrapper = root.querySelector('[data-img-thumbs-wrapper]');
    var thumbItems = imgThumbs
      ? Array.prototype.slice.call(imgThumbs.querySelectorAll('[data-img-thumb]'))
      : [];

    if (imgMain && imgMainWrapper && mainSlides.length > 1) {
      var mainSwiper = null;
      var thumbsSwiper = null;
      var galleryMq = window.matchMedia('(max-width: 1024px)');

      var buildGallery = function () {
        if (mainSwiper) return;
        if (typeof Swiper === 'undefined') {
          return window.setTimeout(buildGallery, 60);
        }

        imgMain.classList.add('swiper');
        imgMainWrapper.classList.add('swiper-wrapper');
        mainSlides.forEach(function (s) { s.classList.add('swiper-slide'); });

        var thumbsConfig;
        if (imgThumbs && imgThumbsWrapper && thumbItems.length) {
          imgThumbs.classList.add('swiper');
          imgThumbsWrapper.classList.add('swiper-wrapper');
          thumbItems.forEach(function (t) { t.classList.add('swiper-slide'); });
          thumbsSwiper = new Swiper(imgThumbs, {
            slidesPerView: 4,
            spaceBetween: 10,
            freeMode: true,
            watchSlidesProgress: true,
            breakpoints: {
              480: { slidesPerView: 5 },
              768: { slidesPerView: 6 }
            }
          });
          thumbsConfig = { swiper: thumbsSwiper };
        }

        mainSwiper = new Swiper(imgMain, {
          slidesPerView: 1,
          spaceBetween: 10,
          grabCursor: true,
          speed: 450,
          watchOverflow: true,
          navigation: {
            prevEl: root.querySelector('[data-img-prev]'),
            nextEl: root.querySelector('[data-img-next]')
          },
          thumbs: thumbsConfig
        });
      };

      var destroyGallery = function () {
        if (mainSwiper) { mainSwiper.destroy(true, true); mainSwiper = null; }
        if (thumbsSwiper) { thumbsSwiper.destroy(true, true); thumbsSwiper = null; }
        imgMain.classList.remove('swiper');
        imgMainWrapper.classList.remove('swiper-wrapper');
        mainSlides.forEach(function (s) { s.classList.remove('swiper-slide'); });
        if (imgThumbs) {
          imgThumbs.classList.remove('swiper');
          imgThumbsWrapper.classList.remove('swiper-wrapper');
          thumbItems.forEach(function (t) { t.classList.remove('swiper-slide'); });
        }
      };

      var applyGallery = function () {
        if (galleryMq.matches) { buildGallery(); } else { destroyGallery(); }
      };

      applyGallery();
      if (galleryMq.addEventListener) {
        galleryMq.addEventListener('change', applyGallery);
      } else if (galleryMq.addListener) {
        galleryMq.addListener(applyGallery);
      }
    }

    /* ---- Variant selection ---- */
    var picker = root.querySelector('[data-variant-picker]');
    var variantsScript = root.querySelector('[data-product-variants]');
    if (!picker || !variantsScript) return;

    var variants = [];
    try {
      variants = JSON.parse(variantsScript.textContent) || [];
    } catch (e) {
      variants = [];
    }
    var idInput = root.querySelector('[data-variant-id-input]');
    var priceMain = root.querySelector('[data-price-main]');
    var priceCompare = root.querySelector('[data-price-compare]');
    var priceSave = root.querySelector('[data-price-save]');
    var addButton = root.querySelector('[data-add-button]');
    var addButtonText = root.querySelector('[data-add-button-text]');
    var productImage = root.querySelector('[data-product-image]');
    var productUrl = root.getAttribute('data-url');

    /* Build current selection from the pre-selected buttons */
    var groups = picker.querySelectorAll('.product-weight-buttons');
    var selected = [];
    groups.forEach(function (group, i) {
      var sel = group.querySelector('.weight-opt.is-selected') || group.querySelector('.weight-opt');
      selected[i] = sel ? sel.getAttribute('data-value') : null;
    });

    /* Find the variant matching a given selection array. Iterate over the
       selection (one entry per option group) so extra/missing entries in a
       variant's options array can never break the match. */
    function findVariantFor(sel) {
      return variants.find(function (v) {
        var opts = v.options || [];
        return sel.every(function (val, i) { return opts[i] === val; });
      });
    }

    /* Mark each weight option as unavailable when the variant it would
       produce (combined with the other current selections) is sold out or
       does not exist. Skipped entirely if variant data is unavailable, so
       the buttons never all get disabled by accident. */
    function refreshAvailability() {
      if (!variants.length) return;
      groups.forEach(function (group, gIndex) {
        group.querySelectorAll('.weight-opt').forEach(function (opt) {
          var candidate = selected.slice();
          candidate[gIndex] = opt.getAttribute('data-value');
          var v = findVariantFor(candidate);
          var unavailable = !v || !v.available;
          opt.classList.toggle('is-unavailable', unavailable);
        });
      });
    }

    function update() {
      /* No variant data: leave the server-rendered price / button as-is. */
      if (!variants.length) return;

      var variant = findVariantFor(selected);

      if (!variant) {
        if (idInput) idInput.setAttribute('disabled', 'disabled');
        if (addButton) addButton.setAttribute('disabled', 'disabled');
        if (addButtonText) addButtonText.textContent = 'Unavailable';
        return;
      }

      if (idInput) { idInput.value = variant.id; idInput.removeAttribute('disabled'); }

      if (priceMain) priceMain.textContent = variant.price;
      if (priceCompare) {
        if (variant.has_compare) {
          priceCompare.textContent = variant.compare_at_price;
          priceCompare.removeAttribute('hidden');
        } else {
          priceCompare.setAttribute('hidden', 'hidden');
        }
      }

      if (priceSave) {
        if (variant.has_compare && variant.save > 0) {
          priceSave.textContent = 'Save ' + variant.save + '%';
          priceSave.removeAttribute('hidden');
        } else {
          priceSave.setAttribute('hidden', 'hidden');
        }
      }

      if (addButton && addButtonText) {
        if (variant.available) {
          addButton.removeAttribute('disabled');
          addButton.removeAttribute('aria-disabled');
          addButtonText.textContent = 'Add to Cart';
        } else {
          addButton.setAttribute('disabled', 'disabled');
          addButtonText.textContent = 'Sold out';
        }
      }

      if (productImage && variant.image) productImage.src = variant.image;
    }

    picker.querySelectorAll('.weight-opt').forEach(function (opt) {
      opt.addEventListener('click', function () {
        /* Sold-out / unavailable weights are still selectable so the page
           reflects them like a standard Shopify product page: the price and
           image update and the Add to Cart button switches to a disabled
           "Sold out" (handled in update()). */
        var group = opt.closest('.product-weight-buttons');
        var index = parseInt(group.getAttribute('data-option-index'), 10);
        selected[index] = opt.getAttribute('data-value');
        group.querySelectorAll('.weight-opt').forEach(function (o) { o.classList.remove('is-selected'); });
        opt.classList.add('is-selected');
        refreshAvailability();
        update();
      });
    });

    /* Re-sync each variant's availability from Shopify's live product JSON so
       the button reflects current stock even when this page was served from a
       cache. Prices stay server-rendered; only the availability flags refresh.
       Any failure falls back silently to the server-rendered data. */
    function revalidateFromLiveData() {
      if (!productUrl || !variants.length || typeof fetch !== 'function') return;
      fetch(productUrl + '.js', { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data || !data.variants) return;
          var liveById = {};
          data.variants.forEach(function (v) { liveById[v.id] = v; });
          variants.forEach(function (v) {
            if (liveById.hasOwnProperty(v.id)) v.available = liveById[v.id].available;
          });
          refreshAvailability();
          update();
        })
        .catch(function () {});
    }

    refreshAvailability();
    update();
    revalidateFromLiveData();
  })();
</script>

{% schema %}
{
  "name": "Product (design)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "info": "Choose which side the product image appears on (desktop).",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image position (mobile)",
      "info": "On mobile the layout stacks. Choose whether the image sits above or below the text.",
      "options": [
        { "value": "bottom", "label": "Below text" },
        { "value": "top", "label": "Above text" }
      ],
      "default": "top"
    },
    {
      "type": "header",
      "content": "Shipping details (for Google structured data)"
    },
    {
      "type": "paragraph",
      "content": "These values feed the shippingDetails in the product structured data so Google can show delivery cost and time. Leave the rate at 0 for free shipping."
    },
    {
      "type": "checkbox",
      "id": "ship_show",
      "label": "Add shipping details to structured data",
      "default": true
    },
    {
      "type": "text",
      "id": "ship_country",
      "label": "Ships to (country code)",
      "default": "IN",
      "info": "Two letter code, for example IN for India."
    },
    {
      "type": "number",
      "id": "ship_rate",
      "label": "Shipping rate",
      "default": 0,
      "info": "Delivery charge in your store currency. Use 0 for free shipping."
    },
    {
      "type": "number",
      "id": "ship_handling_min",
      "label": "Handling time min (days)",
      "default": 1
    },
    {
      "type": "number",
      "id": "ship_handling_max",
      "label": "Handling time max (days)",
      "default": 2
    },
    {
      "type": "number",
      "id": "ship_transit_min",
      "label": "Transit time min (days)",
      "default": 3
    },
    {
      "type": "number",
      "id": "ship_transit_max",
      "label": "Transit time max (days)",
      "default": 7
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Product (design)"
    }
  ]
}
{% endschema %}
