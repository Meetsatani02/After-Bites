{%- comment -%}
  Product logo (brand seal) — a standalone section that shows the After Bites
  gold seal at the right-hand-side bottom. Reuses the same 'gray-logo' snippet
  and the bottom-right positioning + spin used by the "Product feature new"
  section on the home page.

  - No image: the seal floats on its own, aligned to the chosen side (default
    right) at the bottom of the section — matches the product-page mockup.
  - Image set: the seal overlays the image's bottom-right corner, exactly like
    the home-page product-feature card.
{%- endcomment -%}

<style>
  .product-logo-sec {
    box-sizing: border-box;
    width: 100%;
    padding-left: 40px;
    padding-right: 40px;
  }

  .product-logo-inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ---- Standalone seal (no image): float to one side, sit at the bottom ---- */
  .product-logo-standalone {
    display: flex;
    align-items: flex-end;
  }
  .product-logo-standalone.is-left   { justify-content: flex-start; }
  .product-logo-standalone.is-center { justify-content: center; }
  .product-logo-standalone.is-right  { justify-content: flex-end; }

  /* Continuously spin the seal (same feel as the home-page badge). */
  .product-logo-badge svg {
    display: block;
    height: auto;
    transform-origin: center center;
    animation: product-logo-spin 8s linear infinite;
  }

  @keyframes product-logo-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-logo-badge svg { animation: none; }
  }

  /* ---- Image variant: seal overlays the image card's bottom-right corner ---- */
  .product-logo-card {
    position: relative;
    width: 100%;
    border-radius: 40px;
    background-color: #E6DCC2;
  }
  .product-logo-card img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 40px;
  }
  .product-logo-card .product-logo-badge {
    position: absolute;
    bottom: -6%;
    right: -4%;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .product-logo-sec {
      padding-left: 30px;
      padding-right: 30px;
    }
    .product-logo-card .product-logo-badge {
      bottom: -4%;
      right: -4%;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .product-logo-sec {
      padding-left: 20px;
      padding-right: 20px;
      overflow: hidden;
    }
    .product-logo-card .product-logo-badge {
      bottom: -16px;
      right: -20px;
    }
    .product-logo-card .product-logo-badge svg {
      width: 138px;
    }
  }

  @media (max-width: 480px) {
    .product-logo-card .product-logo-badge {
      bottom: -34px;
      right: -21px;
    }
  }
</style>

{%- comment -%} Per-section spacing + seal size (settings-driven). {%- endcomment -%}
{%- style -%}
  .product-logo-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  .product-logo-{{ section.id }} .product-logo-badge svg {
    width: {{ section.settings.logo_size_mobile }}px;
  }

  @media screen and (min-width: 1025px) {
    .product-logo-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .product-logo-{{ section.id }} .product-logo-badge svg {
      width: {{ section.settings.logo_size }}px;
    }
  }
{%- endstyle -%}

<section class="product-logo-sec product-logo-{{ section.id }}">
  <div class="product-logo-inner">
    {%- if section.settings.image != blank -%}
      {%- comment -%} Image card with the seal overlaid at the bottom-right. {%- endcomment -%}
      <div class="product-logo-card">
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: 'After Bites' | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
        <div class="product-logo-badge">
          {% render 'gray-logo' %}
        </div>
      </div>
    {%- else -%}
      {%- comment -%} Standalone seal, aligned to the chosen side. {%- endcomment -%}
      <div class="product-logo-standalone is-{{ section.settings.alignment }}">
        <div class="product-logo-badge">
          {% render 'gray-logo' %}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product logo",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (optional)",
      "info": "If set, the seal overlays this image's bottom-right corner (like the home page). Leave empty to show the seal on its own."
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Seal position",
      "info": "Used when no image is set.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Seal size"
    },
    {
      "type": "range",
      "id": "logo_size",
      "min": 80,
      "max": 300,
      "step": 4,
      "unit": "px",
      "label": "Seal size (desktop)",
      "default": 176
    },
    {
      "type": "range",
      "id": "logo_size_mobile",
      "min": 60,
      "max": 220,
      "step": 4,
      "unit": "px",
      "label": "Seal size (mobile)",
      "default": 120
    },
    {
      "type": "header",
      "content": "Spacing Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Spacing Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Product logo"
    }
  ]
}
{% endschema %}
