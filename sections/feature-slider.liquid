{%- comment -%}
  Horizontal feature / benefits slider — compact image + text cards.
  - Swiper.js carousel: swipe on mobile, multiple cards per row on tablet/desktop
  - Rounded corners, equal spacing, equal-height cards, responsive breakpoints
  - Cards are section blocks (image + title + text)
{%- endcomment -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

{%- liquid
  assign autoplay_ms = section.settings.autoplay_speed | times: 1000
-%}

<style>
  #FeatureSliderSection-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__heading {
    margin: 0 0 36px;
    text-align: {{ section.settings.heading_alignment }};
    font-family: 'Rasbern', 'Inter', sans-serif;
    font-size: clamp(26px, 4.5vw, 44px);
    font-weight: 600;
    color: {{ section.settings.heading_color }};
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__container {
    width: 100%;
    overflow: visible;
  }

  /* Equal-height cards regardless of text length */
  #FeatureSliderSection-{{ section.id }} .swiper-slide {
    height: auto;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: {{ section.settings.card_bg }};
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 14px 34px rgba(28, 48, 37, 0.08);
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__media {
    width: 100%;
    aspect-ratio: 16 / 11;
    background: var(--dark-beige, #e6dcc2);
    overflow: hidden;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__title {
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-size: 19px;
    font-weight: 600;
    line-height: 1.3;
    color: {{ section.settings.card_title_color }};
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__text {
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: {{ section.settings.card_text_color }};
  }

  /* Pagination dots */
  #FeatureSliderSection-{{ section.id }} .feature_slider__pagination {
    position: static;
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__pagination .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    margin: 0 !important;
    background: {{ section.settings.dot_color }};
    opacity: 0.3;
    border-radius: 50%;
    transition: width 0.3s ease, opacity 0.3s ease, border-radius 0.3s ease;
  }

  #FeatureSliderSection-{{ section.id }} .feature_slider__pagination .swiper-pagination-bullet-active {
    width: 24px;
    opacity: 1;
    border-radius: 4px;
  }
</style>

<section id="FeatureSliderSection-{{ section.id }}" class="feature_slider">
  <div class="feature_slider__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="feature_slider__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="swiper feature_slider__container" id="FeatureSlider-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="swiper-slide feature_slider__card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <div class="feature_slider__media">
                  <img
                    class="feature_slider__img"
                    src="{{ block.settings.image | image_url: width: 700 }}"
                    alt="{{ block.settings.title | default: block.settings.image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                </div>
              {%- endif -%}
              <div class="feature_slider__body">
                {%- if block.settings.title != blank -%}
                  <h3 class="feature_slider__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="feature_slider__text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="swiper-slide feature_slider__card">
              <div class="feature_slider__media">
                {{ 'image' | placeholder_svg_tag: 'feature_slider__img' }}
              </div>
              <div class="feature_slider__body">
                <h3 class="feature_slider__title">Feature title</h3>
                <p class="feature_slider__text">Short benefit description goes here to highlight the product.</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="swiper-pagination feature_slider__pagination"></div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  (function () {
    function initFeatureSlider() {
      if (typeof Swiper === 'undefined') {
        return window.setTimeout(initFeatureSlider, 50);
      }

      new Swiper('#FeatureSlider-{{ section.id }}', {
        slidesPerView: 1.15,
        spaceBetween: 16,
        grabCursor: true,
        speed: 500,
        watchOverflow: true,
        {% if section.settings.autoplay %}
          autoplay: {
            delay: {{ autoplay_ms }},
            disableOnInteraction: false,
            pauseOnMouseEnter: true
          },
        {% endif %}
        pagination: {
          el: '#FeatureSlider-{{ section.id }} .feature_slider__pagination',
          clickable: true
        },
        breakpoints: {
          480: { slidesPerView: 1.6, spaceBetween: 18 },
          768: { slidesPerView: 2.4, spaceBetween: 20 },
          1024: { slidesPerView: {{ section.settings.columns_desktop }}, spaceBetween: 24 }
        }
      });
    }

    initFeatureSlider();
  })();
</script>

{% schema %}
{
  "name": "Feature slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why you'll love it"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Cards per row (desktop)",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay delay",
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F4EDDB"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1C3025"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#1C3025"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#4A5B52"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Pagination dot color",
      "default": "#1C3025"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Short benefit description to highlight this product feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature slider",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
