{{ 'global.css' | asset_url | stylesheet_tag }}

<style>
        .after_bite_faq-main {
            padding-block: 66px 80px;
        }

        .afterbite-faq {
            width: 1077px;
            max-width: 100%;
            margin: auto;
        }

        .afterbite-faq-header {
            margin-bottom: 96px;
            text-align: center;
        }

        .afterbite-faq-header h2 {
            font-family: 'Rasbern';
            font-weight: 600;
            font-style: SemiBold;
            font-size: 72px;
            line-height: 110.00000000000001%;
            letter-spacing: 0%;
            color: var(--green);
        }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }

        .faq-question p {
            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 24px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;
            color: var(--green);
        }

        .faq-question svg {
            margin-top: 2px;
            transition: transform 0.3s ease;
        }

        .faq-item.is-open .faq-question svg {
            transform: rotate(180deg);
        }

        .faq-item {
            border-bottom: 1px solid #1C3025;
        }

        .faq-item-inner {
            padding: 24px 8px;
        }

        .faq-answer {
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.3s ease;
        }

        .faq-answer>p {
            overflow: hidden;
            min-height: 0;
            margin: 0;
            font-family: 'Inter';
            font-weight: 400;
            font-size: 20px;
            line-height: 1.6;
            letter-spacing: 0%;
            color: var(--green);
            transition: margin-top 0.3s ease;
        }

        .faq-item.is-open .faq-answer {
            grid-template-rows: 1fr;
        }

        .faq-item.is-open .faq-answer>p {
            margin-top: 20px;
        }

        /* Tablet */
        @media (max-width: 1024px) {
            .after_bite_faq-main {
                padding-block: 48px 56px;
                padding-inline: 30px;
            }

            .afterbite-faq-header {
                margin-bottom: 56px;
            }

            .afterbite-faq-header h2 {
                font-size: 52px;
            }
        }

        /* Mobile */
        @media (max-width: 600px) {
            .after_bite_faq-main {
                padding-block: 40px 48px;
                padding-inline: 20px;
            }

            .afterbite-faq-header {
                margin-bottom: 32px;
            }

            .afterbite-faq-header h2 {
                font-size: 34px;
            }

            .faq-question p {
                font-size: 18px;
                line-height: 1.3;
            }

            .faq-question svg {
                flex-shrink: 0;
                margin-left: 16px;
            }

            .faq-answer>p {
                font-size: 16px;
            }

            .faq-item-inner {
                padding: 20px 4px;
            }
        }
    </style>

        {%- if section.settings.border_image != blank -%}
        <div class="hero-border">
            {{
                section.settings.border_image
                | image_url: width: 3000
                | image_tag:
                    alt: section.settings.border_image.alt | default: 'border',
                    widths: '750, 1100, 1500, 2000, 3000',
                    sizes: '100vw',
                    loading: 'lazy'
            }}
        </div>
        {%- endif -%}

        <section class="after_bite_faq-main global_container">
        <div class="afterbite-faq">
            <div class="afterbite-faq-header">
                <h2>{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
            </div>
            <div class="afterbites-faq-content">
                {%- for block in section.blocks -%}
                    <div class="faq-item" {{ block.shopify_attributes }}>
                        <div class="faq-item-inner">
                            <div class="faq-question">
                                <p>{{ block.settings.question }}</p>
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path d="M0.530273 0.530321L6.53032 6.53027L12.5303 0.530273" stroke="#1C3025"
                                        stroke-width="1.5" stroke-miterlimit="16"></path>
                                </svg>
                            </div>
                            <div class="faq-answer">
                                <p>{{ block.settings.answer | newline_to_br }}</p>
                            </div>
                        </div>
                    </div>
                {%- endfor -%}
            </div>


        </div>
    </section>

    {%- if section.settings.border_image != blank -%}
    <div class="hero-border hero-border--bottom">
        {{
            section.settings.border_image
            | image_url: width: 3000
            | image_tag:
                alt: section.settings.border_image.alt | default: 'border',
                widths: '750, 1100, 1500, 2000, 3000',
                sizes: '100vw',
                loading: 'lazy'
        }}
    </div>
    {%- endif -%}

    <script>
        (function () {
            const items = document.querySelectorAll('.afterbites-faq-content .faq-item');
            items.forEach(function (item) {
                const question = item.querySelector('.faq-question');
                if (!question) return;
                question.addEventListener('click', function () {
                    item.classList.toggle('is-open');
                });
            });
        })();
    </script>


{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border image (top & bottom)",
      "info": "Decorative border shown above and below the section."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is After Bites Paan Mukhwas?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "After Bites Paan Mukhwas is a traditional, tobacco-free after-meal mouth freshener with the sweet, cooling taste of classic paan."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is After Bites Paan Mukhwas?",
            "answer": "After Bites Paan Mukhwas is a traditional, tobacco-free after-meal mouth freshener with the sweet, cooling taste of classic paan — ready to eat, no mess."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is After Bites paan mukhwas tobacco-free?",
            "answer": "Yes — our paan mukhwas is 100% tobacco-free and supari-free, made with natural ingredients only."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does paan mukhwas help with digestion?",
            "answer": "Yes. The fennel and betel leaf in our pan mukhwas soothe the stomach and freshen your breath after meals."
          }
        }
      ]
    }
  ]
}

{% endschema %}
