{{ 'global.css' | asset_url | stylesheet_tag }}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');

  .annocement-wrapper {
      background: var(--green);
      padding: 12px 12px;
  }

  .annocement-container {
      max-width: 1440px;
      margin: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
  }

  .annocement-left,
  .annocement-right {
      display: flex;
      align-items: center;
      gap: 20px;
      color: var(--beige);
      font-family: "Inter", sans-serif;
      font-size: 14px;
      font-weight: 400;
      line-height: 14px;
  }

  .annocement-right {
      text-align: right;
  }

  @media (max-width: 1024px) {

      .annocement-wrapper {
          padding: 12px 30px;
      }

      .annocement-left img,
      .annocement-right img {
          display: none;
      }

      .annocement-left,
      .annocement-right {
          font-size: 12px;
      }
  }

  @media (max-width: 768px) {

      .annocement-wrapper {
          padding: 12px 20px;
      }

      .annocement-container {
          flex-direction: column;
          gap: 10px;
      }

      .annocement-left,
      .annocement-right{
          text-align: center;
      }
  }
</style>

<section class="annocement-wrapper">
  <div class="annocement-container">
    <div class="annocement-left">
      {%- if section.settings.left_image != blank -%}
        <img src="{{ section.settings.left_image | image_url: width: 120 }}" alt="{{ section.settings.left_image.alt | escape }}">
      {%- elsif section.settings.left_image_url != blank -%}
        <img src="{{ section.settings.left_image_url }}" alt="left-line">
      {%- endif -%}
      <p>{{ section.settings.left_text }}</p>
    </div>

    <div class="annocement-right">
      <p>{{ section.settings.right_text }}</p>
      {%- if section.settings.right_image != blank -%}
        <img src="{{ section.settings.right_image | image_url: width: 120 }}" alt="{{ section.settings.right_image.alt | escape }}">
      {%- elsif section.settings.right_image_url != blank -%}
        <img src="{{ section.settings.right_image_url }}" alt="right-line">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (upload)"
    },
    {
      "type": "url",
      "id": "left_image_url",
      "label": "Left image URL (fallback)",
      "info": "Used if no image is uploaded above.",
      "default": "https://cdn.shopify.com/s/files/1/0742/9839/2711/files/right-line.png?v=1780039435"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry."
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right text",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry."
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (upload)"
    },
    {
      "type": "url",
      "id": "right_image_url",
      "label": "Right image URL (fallback)",
      "info": "Used if no image is uploaded above.",
      "default": "https://cdn.shopify.com/s/files/1/0742/9839/2711/files/left-line.png?v=1780039435"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
