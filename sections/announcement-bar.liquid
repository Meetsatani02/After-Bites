{%- liquid
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign left_text = section.settings.left_text
  assign right_text = section.settings.right_text
  assign left_image = section.settings.left_image
  assign right_image = section.settings.right_image
  assign left_image_mobile = section.settings.left_image_mobile
  assign right_image_mobile = section.settings.right_image_mobile
  assign left_image_url = section.settings.left_image_url
  assign right_image_url = section.settings.right_image_url
  assign link = section.settings.link
-%}

{%- style -%}
  .announcement-wrapper-{{ section.id }} {
    background: {{ bg_color }};
    padding: 12px 12px;
  }

  .announcement-container-{{ section.id }} {
    max-width: max-content;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  .announcement-container-{{ section.id }} .announcement-left,
  .announcement-container-{{ section.id }} .announcement-right {
    display: flex;
    align-items: center;
    gap: 20px;
    color: {{ text_color }};
    font-family: var(--font-body-family), 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }

  .announcement-container-{{ section.id }} .announcement-right {
    text-align: right;
  }

  .announcement-container-{{ section.id }} .announcement-icon {
    display: inline-block;
    height: auto;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .announcement-container-{{ section.id }} p {
    margin: 0;
  }

  .announcement-container-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
  }

  @media (max-width: 1024px) {
    .announcement-wrapper-{{ section.id }} {
      padding: 12px 30px;
    }
    /* .announcement-container-{{ section.id }} .announcement-icon {
      display: none;
    } */
    .announcement-container-{{ section.id }} .announcement-left,
    .announcement-container-{{ section.id }} .announcement-right {
      font-size: 12px;
    }
  }

  @media (max-width: 768px) {
    .announcement-wrapper-{{ section.id }} {
      padding: 12px 0px;
    }
    /* .announcement-container-{{ section.id }} {
      flex-direction: column;
      gap: 8px;
    } */
    .announcement-container-{{ section.id }} .announcement-left,
    .announcement-container-{{ section.id }} .announcement-right {
      text-align: center;
      justify-content: center;
    }
  }
{%- endstyle -%}

<section class="announcement-wrapper-{{ section.id }}">
  <div class="announcement-container-{{ section.id }}">
    {%- liquid
      assign left_desktop_src = ''
      if left_image != blank
        assign left_desktop_src = left_image | image_url: width: 240
      elsif left_image_url != blank
        assign left_desktop_src = left_image_url
      endif

      assign left_mobile_src = ''
      if left_image_mobile != blank
        assign left_mobile_src = left_image_mobile | image_url: width: 240
      else
        assign left_mobile_src = left_desktop_src
      endif
    -%}
    {%- if left_desktop_src != blank -%}
      <div class="announcement-left">
        <picture>
          <source media="(max-width: 480px)" srcset="{{ left_mobile_src }}">
          <source media="(min-width: 481px)" srcset="{{ left_desktop_src }}">
          <img
            src="{{ left_desktop_src }}"
            alt="announcement icon"
            class="announcement-icon"
            loading="lazy"
          >
        </picture>
      </div>
    {%- endif -%}

    {%- if left_text != blank -%}
      <div class="announcement-left">
        <p>
          {%- if link != blank -%}<a href="{{ link }}">{%- endif -%}
            {{ left_text }}
          {%- if link != blank -%}</a>{%- endif -%}
        </p>
      </div>
    {%- endif -%}

    {%- liquid
      assign right_desktop_src = ''
      if right_image != blank
        assign right_desktop_src = right_image | image_url: width: 240
      elsif right_image_url != blank
        assign right_desktop_src = right_image_url
      endif

      assign right_mobile_src = ''
      if right_image_mobile != blank
        assign right_mobile_src = right_image_mobile | image_url: width: 240
      else
        assign right_mobile_src = right_desktop_src
      endif
    -%}
    {%- if right_desktop_src != blank -%}
      <div class="announcement-right">
        <picture>
          <source media="(max-width: 480px)" srcset="{{ right_mobile_src }}">
          <source media="(min-width: 481px)" srcset="{{ right_desktop_src }}">
          <img
            src="{{ right_desktop_src }}"
            alt="announcement icon"
            class="announcement-icon"
            loading="lazy"
          >
        </picture>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1f4d2b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5ecd9"
    },
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "left_image_mobile",
      "label": "Left image (mobile)",
      "info": "Shown on screens 480px and below. Falls back to the desktop image if empty."
    },
    {
      "type": "url",
      "id": "left_image_url",
      "label": "Left image URL (fallback)",
      "info": "Used if no desktop image is uploaded above."
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "Free shipping on orders over $50."
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right text",
      "default": "New arrivals dropping every week."
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "right_image_mobile",
      "label": "Right image (mobile)",
      "info": "Shown on screens 480px and below. Falls back to the desktop image if empty."
    },
    {
      "type": "url",
      "id": "right_image_url",
      "label": "Right image URL (fallback)",
      "info": "Used if no desktop image is uploaded above."
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link (wraps both texts)"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
