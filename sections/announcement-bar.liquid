{%- liquid
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign left_text = section.settings.left_text
  assign right_text = section.settings.right_text
  assign left_image = section.settings.left_image
  assign right_image = section.settings.right_image
  assign left_image_url = section.settings.left_image_url
  assign right_image_url = section.settings.right_image_url
  assign link = section.settings.link
-%}

{%- style -%}
  .announcement-wrapper-{{ section.id }} {
    background: {{ bg_color }};
    padding: 12px 12px;
  }

  .announcement-container-{{ section.id }} {
    max-width: max-content;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  .announcement-container-{{ section.id }} .announcement-left,
  .announcement-container-{{ section.id }} .announcement-right {
    display: flex;
    align-items: center;
    gap: 20px;
    color: {{ text_color }};
    font-family: var(--font-body-family), 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }

  .announcement-container-{{ section.id }} .announcement-right {
    text-align: right;
  }

  .announcement-container-{{ section.id }} .announcement-icon {
    display: inline-block;
    height: auto;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .announcement-container-{{ section.id }} p {
    margin: 0;
  }

  .announcement-container-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
  }

  @media (max-width: 1024px) {
    .announcement-wrapper-{{ section.id }} {
      padding: 12px 30px;
    }
    /* .announcement-container-{{ section.id }} .announcement-icon {
      display: none;
    } */
    .announcement-container-{{ section.id }} .announcement-left,
    .announcement-container-{{ section.id }} .announcement-right {
      font-size: 12px;
    }
  }

  @media (max-width: 768px) {
    .announcement-wrapper-{{ section.id }} {
      padding: 12px 0px;
    }
    /* .announcement-container-{{ section.id }} {
      flex-direction: column;
      gap: 8px;
    } */
    .announcement-container-{{ section.id }} .announcement-left,
    .announcement-container-{{ section.id }} .announcement-right {
      text-align: center;
      justify-content: center;
    }
  }
{%- endstyle -%}

<section class="announcement-wrapper-{{ section.id }}">
  <div class="announcement-container-{{ section.id }}">
    {%- if left_image != blank or left_image_url != blank -%}
      <div class="announcement-left">
        {%- if left_image != blank -%}
          {{
            left_image
            | image_url: width: 240
            | image_tag:
              loading: 'lazy',
              width: left_image.width,
              height: left_image.height,
              class: 'announcement-icon',
              alt: left_image.alt | default: 'announcement icon',
              widths: '60, 120, 180, 240',
              sizes: '112px'
          }}
        {%- elsif left_image_url != blank -%}
          <img
            src="{{ left_image_url }}"
            alt="announcement icon"
            class="announcement-icon"
            loading="lazy"
            width="112"
            height="17"
          >
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if left_text != blank -%}
      <div class="announcement-left">
        <p>
          {%- if link != blank -%}<a href="{{ link }}">{%- endif -%}
            {{ left_text }}
          {%- if link != blank -%}</a>{%- endif -%}
        </p>
      </div>
    {%- endif -%}

    {%- if right_image != blank or right_image_url != blank -%}
      <div class="announcement-right">
        {%- if right_image != blank -%}
          {{
            right_image
            | image_url: width: 240
            | image_tag:
              loading: 'lazy',
              width: right_image.width,
              height: right_image.height,
              class: 'announcement-icon',
              alt: right_image.alt | default: 'announcement icon',
              widths: '60, 120, 180, 240',
              sizes: '112px'
          }}
        {%- elsif right_image_url != blank -%}
          <img
            src="{{ right_image_url }}"
            alt="announcement icon"
            class="announcement-icon"
            loading="lazy"
            width="112"
            height="17"
          >
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1f4d2b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5ecd9"
    },
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (upload)"
    },
    {
      "type": "url",
      "id": "left_image_url",
      "label": "Left image URL (fallback)",
      "info": "Used if no image is uploaded above."
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "Free shipping on orders over $50."
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right text",
      "default": "New arrivals dropping every week."
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (upload)"
    },
    {
      "type": "url",
      "id": "right_image_url",
      "label": "Right image URL (fallback)",
      "info": "Used if no image is uploaded above."
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link (wraps both texts)"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
