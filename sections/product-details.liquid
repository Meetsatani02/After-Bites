
<style>
  .pd-section {
    background: var(--green);
    position: relative;
    overflow: hidden;
  }

  .pd-container {
    display: flex;
    align-items: stretch;
    width: 100%;
  }

  /* Image-left variant: flip the row so the image bleeds to the left edge. */
  .pd-container--image-left { flex-direction: row-reverse; }

  /* Both halves locked to 50% on desktop. */
  .pd-content,
  .pd-img {
    flex: 0 0 50%;
    max-width: 50%;
    min-width: 0;
    box-sizing: border-box;
  }

  /* Align text with the 1440px-centered layout; image bleeds to the edge. */
  .pd-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 72px;
    padding-bottom: 72px;
    padding-left: max(40px, calc((100vw - 1440px) / 2 + 40px));
    padding-right: 40px;
    color: var(--beige);
  }
  .pd-container--image-left .pd-content {
    padding-left: 40px;
    padding-right: max(40px, calc((100vw - 1440px) / 2 + 40px));
  }

  .pd-content h2 {
    font-family: 'Rasbern', serif;
    font-weight: 600;
    font-size: 56px;
    line-height: 1.05;
    letter-spacing: 0;
    margin: 0 0 22px 0;
    color: var(--beige);
  }

  .pd-content p {
    max-width: 506px;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: var(--beige);
    opacity: 0.88;
    margin: 0 0 30px 0;
  }

  .pd-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pd-list li {
    position: relative;
    padding-left: 22px;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    color: var(--beige);
  }
  .pd-list li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--beige);
  }

  .pd-img {
    display: flex;
    line-height: 0;
  }
  .pd-img picture { width: 100%; }
  .pd-img picture,
  .pd-img img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .pd-container {
      align-items: flex-start;
      flex-direction: column;
    }
    .pd-container--image-mobile-top { flex-direction: column-reverse; }
    .pd-container--image-mobile-bottom { flex-direction: column; }

    .pd-content,
    .pd-img {
      flex: none;
      width: 100%;
      max-width: 100%;
    }
    .pd-content,
    .pd-container--image-left .pd-content {
      padding: 56px 20px;
    }
    .pd-img img { height: auto; }
  }

  @media (max-width: 768px) {
    .pd-content h2 { font-size: 38px; }
    .pd-content,
    .pd-container--image-left .pd-content { padding: 44px 20px; }
  }
</style>

<section class="pd-section product-wrapper" id="ProductDetails-{{ section.id }}">
  {%- if section.settings.border_image != blank -%}
    {%- assign border_alt = section.settings.border_image.alt | default: 'border' -%}
    <div class="hero-border">
      {{ section.settings.border_image | image_url: width: 3000 | image_tag: alt: border_alt, widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy' }}
    </div>
  {%- endif -%}

  <div class="pd-container pd-container--image-{{ section.settings.image_position }} pd-container--image-mobile-{{ section.settings.image_position_mobile }}">
    <div class="pd-content">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="pd-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'list_item' and block.settings.text != blank -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="pd-img">
      {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
        {%- liquid
          assign desktop_image = section.settings.image | default: section.settings.image_mobile
          assign image_height = desktop_image.width | divided_by: desktop_image.aspect_ratio
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 768px)" srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}">
          {%- endif -%}
          {%- if section.settings.image != blank -%}
            <source media="(min-width: 769px)" srcset="{{ section.settings.image | image_url: width: 1500 }}">
          {%- endif -%}
          <img
            src="{{ desktop_image | image_url: width: 1500 }}"
            alt="{{ desktop_image.alt | default: 'product details image' | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ image_height }}"
            loading="lazy"
          >
        </picture>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.border_image != blank -%}
    {%- assign border_alt = section.settings.border_image.alt | default: 'border' -%}
    <div class="hero-border hero-border--bottom">
      {{ section.settings.border_image | image_url: width: 3000 | image_tag: alt: border_alt, widths: '750, 1100, 1500, 2000, 3000', sizes: '100vw', loading: 'lazy' }}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Product Details",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "info": "Choose which side the image appears on (desktop).",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image position (mobile)",
      "options": [
        { "value": "top", "label": "Above text" },
        { "value": "bottom", "label": "Below text" }
      ],
      "default": "top"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Replaces the image on screens 768px and below."
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border image (top & bottom)",
      "info": "Decorative checkered border shown above and below the section."
    }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Lorem Ipsum is simply dummy text"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Product Details",
      "blocks": [
        { "type": "list_item" },
        { "type": "list_item" },
        { "type": "list_item" },
        { "type": "list_item" },
        { "type": "list_item" },
        { "type": "list_item" }
      ]
    }
  ]
}
{% endschema %}
