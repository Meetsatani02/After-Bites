{{ 'global.css' | asset_url | stylesheet_tag }}

 <style>
        body {
            background-color: var(--beige);
        }

        /* .demo-width {
            max-width: 638px;
            width: 100%;
            margin: auto;
            background-color: var(--beige);
            border: 1px solid black;
        } */



        .product-heading h1,
        .product-heading h2 {
            font-family: 'Rasbern';
            font-weight: 600;
            font-style: SemiBold;
            font-size: 56px;
            line-height: 1.1;
            letter-spacing: 0%;
            color: var(--green);
        }

        .product-review {
            display: flex;
            gap: 12px;
            margin: 16px 0px 20px 0px;
        }

        .pro-review-start {
            gap: 5px;
            display: flex;
        }

        .product-description-content {
            /* max-width: 540px; */
            width: 100%;
        }

        .product-description-content p {
            font-family: 'Inter';
            font-weight: 400;
            font-size: 16px;
            line-height: 1;
            letter-spacing: 0%;
            color: var(--green);
        }

        .product-price {
            margin: 32px 0px 56px 0px;
            display: flex;
            gap: 10px;
        }

        .product-price-main span {
            font-family: 'Rasbern';
            font-weight: 700;
            font-style: Bold;
            font-size: 44px;
            line-height: 1.15;
            letter-spacing: 2%;
            text-transform: uppercase;
            color: var(--green);
        }

        .product-price-compare {
            font-family: 'Rasbern';
            font-weight: 400;
            font-style: Regular;
            font-size: 20px;
            line-height: 1.15;
            letter-spacing: 2%;
            text-transform: uppercase;
            color: #312409;
            display: flex;
            align-items: self-end;
            text-decoration: line-through;
        }

        .product-weight {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .product-weight-text {
            font-family: Inter;
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;

        }

        .product-weight-buttons {
            display: flex;
            gap: 12px;
        }

        .product-weight-buttons span {
            /* font-family: Gilroy-Medium; */
            font-weight: 400;
            font-size: 18px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;
            color: var(--green);
            padding: 10px 26px;
            border: 1px solid var(--green);
            border-radius: 8px;
            cursor: pointer;
        }

        .product-weight-buttons span:hover {
            color: var(--beige);
            background-color: var(--green);
        }

        .product-quantity-cart-button {
            margin-block: 48px;
            display: flex;
            gap: 16px;
        }

        .product-quntity-button-input {
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            border: 1.5px solid #1C3025;
            padding: 14px 20px;
            background-color: var(--beige);
        }

        .product-quntity-button-input .qty-btn {
            border: none;
            background: transparent;
            cursor: pointer;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;

        }

        .product-quntity-button-input .qty-btn img {
            display: block;
            width: 16px;
            height: 16px;
        }

        .product-quntity-button-input .qty-value {
            color: var(--green);

            border: none;
            background: transparent;
            outline: none;
            width: 75px;
            padding: 0;

            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 1.5;
            letter-spacing: -2%;
            text-align: center;
            vertical-align: middle;
        }

        .product-buy-button {
            width: 100%;
        }

        .product-buy-button button {
            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 1.5;
            letter-spacing: -2%;
            vertical-align: middle;
            color: #ffff;
            background-color: var(--green);
            padding-block: 15px;
            border-radius: 12px;
            width: -webkit-fill-available;
        }

        .product-buy-shipping-inner {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            padding-bottom: 32px;
            border-bottom: 1px solid #1C3025
        }

        .product-icon-text span {
            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 18px;
            line-height: 24px;
            letter-spacing: 1%;
            text-align: center;
            vertical-align: bottom;

        }

        .product-buy-shipping-icon-text {
            display: flex;
            justify-content: center;
        }

        .border-right {
            border-right: 2px solid rgba(28, 48, 37, 0.5);
        }

        .product-icon-text {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 160px;
            justify-content: center;
            text-align: center;
        }

        .product-icon-text img {
            width: fit-content;
            height: auto;
        }



        .product-ingredients-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }

        .product-ingredients-inner p {
            font-family: 'Inter';
            font-weight: 500;
            font-style: Medium;
            font-size: 20px;
            line-height: 26px;
            letter-spacing: 1%;
            vertical-align: bottom;
        }

        .product-ingredients-inner svg {
            margin-top: 2px;
            transition: transform 0.3s ease;
        }

        .product-ingredients.is-open .product-ingredients-inner svg {
            transform: rotate(180deg);
        }

        .border-bottom {
            border-bottom: 1px solid #1C3025;
        }
        .product-ingrdients-first-inner{
            padding: 24px 8px;
        }
        .product-ingredients-description{
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.3s ease;
        }

        .product-ingredients-description > ul{
            overflow: hidden;
            min-height: 0;
            margin: 0;
            padding: 0;
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            transition: margin-top 0.3s ease;
        }

        .product-ingredients-description li{
            font-family: 'Inter';
            font-weight: 400;
            font-size: 15px;
            line-height: 1;
            letter-spacing: 0%;
            color: var(--green);
            padding: 9px 16px;
            border: 1px solid var(--green);
            border-radius: 999px;
            background-color: var(--beige);
            transition: color 0.2s ease, background-color 0.2s ease;
        }

        .product-ingredients-description li:hover{
            color: var(--beige);
            background-color: var(--green);
        }

        .product-ingredients.is-open .product-ingredients-description{
            grid-template-rows: 1fr;
        }

        .product-ingredients.is-open .product-ingredients-description > ul{
            margin-top: 20px;
        }
    </style>

<section class="product-new-section">
  <div class="product-new-container product-new-container--image-{{ section.settings.image_position }} product-new-container--image-mobile-{{ section.settings.image_position_mobile }}">
    <div class="product-new-content">
      <h2>{{ section.settings.heading | default: 'product' }}</h2>
    </div>

    <div class="product-new-img">
      {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
        {%- liquid
          assign desktop_image = section.settings.image | default: section.settings.image_mobile
          assign image_height = desktop_image.width | divided_by: desktop_image.aspect_ratio
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}"
            >
          {%- endif -%}
          {%- if section.settings.image != blank -%}
            <source
              media="(min-width: 769px)"
              srcset="{{ section.settings.image | image_url: width: 1500 }}"
            >
          {%- endif -%}
          <img
            src="{{ desktop_image | image_url: width: 1500 }}"
            alt="{{ desktop_image.alt | default: 'product image' | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ image_height }}"
            fetchpriority="high"
          >
        </picture>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product New",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "product"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "info": "Choose which side the image appears on.",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image position (mobile)",
      "info": "On mobile the layout stacks. Choose whether the image sits above or below the text.",
      "options": [
        {
          "value": "bottom",
          "label": "Below text"
        },
        {
          "value": "top",
          "label": "Above text"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Shown on desktop (and on mobile if no mobile image is set)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Replaces the image on screens 768px and below."
    }
  ],
  "presets": [
    {
      "name": "Product New"
    }
  ]
}
{% endschema %}
