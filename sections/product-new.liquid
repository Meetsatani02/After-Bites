{{ 'global.css' | asset_url | stylesheet_tag }}

<section class="product-new-section">
  <div class="product-new-container product-new-container--image-{{ section.settings.image_position }} product-new-container--image-mobile-{{ section.settings.image_position_mobile }}">
    <div class="product-new-content">
      <h2>{{ section.settings.heading | default: 'product' }}</h2>
    </div>

    <div class="product-new-img">
      {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}
        {%- liquid
          assign desktop_image = section.settings.image | default: section.settings.image_mobile
          assign image_height = desktop_image.width | divided_by: desktop_image.aspect_ratio
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}"
            >
          {%- endif -%}
          {%- if section.settings.image != blank -%}
            <source
              media="(min-width: 769px)"
              srcset="{{ section.settings.image | image_url: width: 1500 }}"
            >
          {%- endif -%}
          <img
            src="{{ desktop_image | image_url: width: 1500 }}"
            alt="{{ desktop_image.alt | default: 'product image' | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ image_height }}"
            fetchpriority="high"
          >
        </picture>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product New",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "product"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "info": "Choose which side the image appears on.",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image position (mobile)",
      "info": "On mobile the layout stacks. Choose whether the image sits above or below the text.",
      "options": [
        {
          "value": "bottom",
          "label": "Below text"
        },
        {
          "value": "top",
          "label": "Above text"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Shown on desktop (and on mobile if no mobile image is set)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Replaces the image on screens 768px and below."
    }
  ],
  "presets": [
    {
      "name": "Product New"
    }
  ]
}
{% endschema %}
