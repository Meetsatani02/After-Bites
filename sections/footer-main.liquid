                            </svg>
                        </a>
                        {%- if twitter_url != blank -%}
                            <a href="{{ twitter_url }}" aria-label="X" target="_blank" rel="noopener">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
                                </svg>
                            </a>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Footer Main",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "brand_word_1",
      "label": "Brand word (left)",
      "default": "After"
    },
    {
      "type": "text",
      "id": "brand_word_2",
      "label": "Brand word (right)",
      "default": "Bites"
    },
    {
      "type": "paragraph",
      "content": "The centered logo uses your theme logo (Settings → Logo) when set."
    },
    {
      "type": "header",
      "content": "Menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "footer",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Show email signup"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email field placeholder",
      "default": "Enter Your Email ID"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Button label",
      "default": "Submit"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "footer_description",
      "label": "Description",
      "default": "<p>After Bites brings you the best pan mukhwas — tobacco-free wet and dry paan mukhwas mouth fresheners made with natural paan leaves, gulkand and fennel for a sweet, refreshing taste after every meal.</p>"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "rights_text",
      "label": "Rights text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "Show social icons"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "paragraph",
      "content": "TikTok and Instagram always show. Add a URL to make an icon clickable; leave blank to keep it as a placeholder. Set the X or YouTube URL to also show those icons. Falls back to Theme settings → Social media when left empty."
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    }
  ],
  "presets": [
    {
      "name": "Footer Main"
    }
  ]
}
{% endschema %}
