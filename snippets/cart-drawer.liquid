{% comment %}
  Renders cart drawer — custom After Bites design.

  Keeps every JS hook cart.js / cart-drawer.js rely on:
  cart-drawer, cart-drawer-items, #CartDrawer-Form, .js-contents,
  .cart-drawer__footer, #CartDrawer-Item-N, Drawer-quantity-N,
  cart-remove-button, .loading__spinner, the a11y status/error nodes.

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer { visibility: hidden; }

  /* ---- Shell ---- */
  .cart-drawer .drawer__inner {
    background-color: var(--beige);
    color: var(--green);
    display: flex;
    flex-direction: column;
    padding: 0;
    height: 100%;
  }

  /* ---- Header ---- */
  .cart-drawer .drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 22px;
    margin: 0;
    border-bottom: 1px solid rgba(28, 48, 37, 0.15);
  }
  .cart-drawer .drawer__heading {
    margin: 0;
    font-family: var(--font-heading-family, inherit);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.2;
    color: var(--green);
  }
  .cart-drawer .drawer__close {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--green);
    cursor: pointer;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }
  .cart-drawer .drawer__close:hover { background-color: rgba(28, 48, 37, 0.08); }
  .cart-drawer .drawer__close .svg-wrapper,
  .cart-drawer .drawer__close svg { width: 18px; height: 18px; }

  /* ---- Scrollable items area ---- */
  .cart-drawer cart-drawer-items {
    display: block;
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 8px 22px 4px;
  }
  .cart-drawer .ab-cart-list { display: flex; flex-direction: column; }

  /* ---- Line item ---- */
  .cart-drawer .ab-cart-item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 14px;
    align-items: start;
    padding: 18px 0;
    border-bottom: 1px solid rgba(28, 48, 37, 0.12);
    position: relative;
  }
  .cart-drawer .ab-cart-item__media {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    display: block;
  }
  .cart-drawer .ab-cart-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cart-drawer .ab-cart-item__info { min-width: 0; }
  .cart-drawer .ab-cart-item__title {
    display: block;
    font-family: var(--font-heading-family, inherit);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.3;
    color: var(--green);
    text-decoration: none;
    margin-bottom: 4px;
  }
  .cart-drawer .ab-cart-item__title:hover { text-decoration: underline; }
  .cart-drawer .ab-cart-item__desc {
    margin: 0 0 4px;
    font-size: 12.5px;
    line-height: 1.45;
    color: rgba(28, 48, 37, 0.62);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cart-drawer .ab-cart-item__variant {
    margin: 0 0 8px;
    font-size: 12px;
    color: rgba(28, 48, 37, 0.6);
  }
  .cart-drawer .ab-cart-item__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 10px;
  }
  .cart-drawer .ab-cart-item__price {
    font-weight: 600;
    font-size: 16px;
    color: var(--green);
    white-space: nowrap;
  }
  .cart-drawer .ab-cart-item__price s {
    display: block;
    font-weight: 400;
    font-size: 12px;
    opacity: 0.55;
  }

  /* ---- Quantity stepper ---- */
  .cart-drawer .ab-qty {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--green);
    border-radius: 10px;
    overflow: hidden;
    background: transparent;
    width: auto;
    min-height: 40px;
  }
  .cart-drawer .ab-qty .quantity__button {
    width: 38px;
    height: 38px;
    border: none;
    background: transparent;
    color: var(--green);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .cart-drawer .ab-qty .quantity__button:hover { background: rgba(28, 48, 37, 0.08); }
  .cart-drawer .ab-qty .quantity__input {
    width: 38px;
    border: none;
    background: transparent;
    text-align: center;
    color: var(--green);
    font-weight: 600;
    font-size: 15px;
    padding: 0;
    -moz-appearance: textfield;
  }
  .cart-drawer .ab-qty .quantity__input::-webkit-outer-spin-button,
  .cart-drawer .ab-qty .quantity__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ---- Remove button ---- */
  .cart-drawer .ab-cart-item__remove {
    position: absolute;
    top: 16px;
    right: 0;
  }
  .cart-drawer .ab-cart-item__remove button {
    border: none;
    background: transparent;
    color: rgba(28, 48, 37, 0.55);
    cursor: pointer;
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 6px;
  }
  .cart-drawer .ab-cart-item__remove button:hover { color: var(--green); background: rgba(28, 48, 37, 0.08); }
  .cart-drawer .ab-cart-item__remove .svg-wrapper,
  .cart-drawer .ab-cart-item__remove svg { width: 14px; height: 14px; }

  .cart-drawer .cart-item__error {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #b00020;
    font-size: 12px;
    margin-top: 6px;
  }
  .cart-drawer .cart-item__error:empty,
  .cart-drawer .cart-item__error .cart-item__error-text:empty { display: none; }
  .cart-drawer .cart-item__error svg { width: 14px; height: 14px; }

  /* ---- Note ---- */
  .cart-drawer .ab-cart-note { display: block; margin: 18px 0 6px; }
  .cart-drawer .ab-cart-note__label {
    display: block;
    font-size: 13px;
    color: rgba(28, 48, 37, 0.7);
    margin-bottom: 8px;
  }
  .cart-drawer .ab-cart-note__input {
    width: 100%;
    min-height: 96px;
    resize: vertical;
    border: 1px solid rgba(28, 48, 37, 0.25);
    border-radius: 8px;
    background: rgba(28, 48, 37, 0.04);
    padding: 12px;
    font-family: inherit;
    font-size: 14px;
    color: var(--green);
    outline: none;
  }
  .cart-drawer .ab-cart-note__input:focus { border-color: var(--green); }

  /* ---- Footer / totals ---- */
  .cart-drawer .cart-drawer__footer {
    flex: 0 0 auto;
    padding: 18px 22px 22px;
    border-top: 1px dashed rgba(28, 48, 37, 0.3);
    background-color: var(--beige);
  }
  .cart-drawer .ab-totals { display: flex; flex-direction: column; gap: 8px; }
  .cart-drawer .ab-totals__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 14px;
    color: var(--green);
  }
  .cart-drawer .ab-totals__row span:last-child { font-weight: 600; }
  .cart-drawer .ab-totals__subtotal {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(28, 48, 37, 0.18);
  }
  .cart-drawer .ab-totals__subtotal span {
    font-family: var(--font-heading-family, inherit);
    font-weight: 700;
    font-size: 22px;
    color: var(--green);
  }
  .cart-drawer .ab-totals__note {
    margin: 6px 0 0;
    font-size: 12px;
    color: rgba(28, 48, 37, 0.6);
  }

  /* ---- Promocode ---- */
  .cart-drawer .ab-promo {
    display: flex;
    align-items: center;
    margin: 16px 0;
    border: 1px solid rgba(28, 48, 37, 0.3);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(28, 48, 37, 0.04);
  }
  .cart-drawer .ab-promo__input {
    flex: 1 1 auto;
    border: none;
    background: transparent;
    padding: 13px 14px;
    font-family: inherit;
    font-size: 14px;
    color: var(--green);
    outline: none;
  }
  .cart-drawer .ab-promo__input::placeholder { color: rgba(28, 48, 37, 0.5); }
  .cart-drawer .ab-promo__apply {
    flex: 0 0 auto;
    border: none;
    background: transparent;
    padding: 0 18px;
    align-self: stretch;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--green);
    cursor: pointer;
  }
  .cart-drawer .ab-promo__apply:hover { text-decoration: underline; }

  /* ---- Buttons (clean — no double border) ---- */
  .cart-drawer .ab-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 54px;
    padding: 15px 24px;
    border: none;
    border-radius: 10px;
    background: var(--green);
    color: var(--beige);
    font-family: inherit;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    box-shadow: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .cart-drawer .ab-btn:hover {
    background: #16261d;
    color: #fff;
  }
  .cart-drawer .ab-btn[disabled],
  .cart-drawer .ab-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ---- Empty state ---- */
  .cart-drawer .ab-cart-empty {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 18px;
    padding: 40px 28px;
  }
  .cart-drawer .ab-cart-empty .cart__empty-text {
    margin: 0;
    font-family: var(--font-heading-family, inherit);
    font-weight: 600;
    font-size: 24px;
    color: var(--green);
  }
  .cart-drawer .ab-cart-empty .ab-btn { width: auto; min-width: 240px; }
  .cart-drawer .ab-cart-empty__login { margin: 4px 0 0; font-size: 14px; color: var(--green); }
  .cart-drawer .ab-cart-empty__login a { color: var(--green); }

  /* Spinner overlay sits over the item while updating */
  .cart-drawer .ab-cart-item .loading__spinner {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(244, 237, 219, 0.6);
  }
  .cart-drawer .ab-cart-item .loading__spinner:not(.hidden) { display: flex; }
  .cart-drawer .ab-cart-item .loading__spinner svg { width: 22px; height: 22px; }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="Your Cart"
      tabindex="-1"
    >
      <div class="drawer__header">
        <h2 class="drawer__heading">Your Cart</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- if cart == empty -%}
        <div class="drawer__inner-empty ab-cart-empty">
          <h2 class="cart__empty-text">Your cart is empty</h2>
          <a href="{{ routes.all_products_collection_url }}" class="ab-btn ab-btn--primary">
            Continue shopping
          </a>
          {%- if shop.customer_accounts_enabled and customer == null -%}
            <p class="ab-cart-empty__login">
              Have an account?<br>
              {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
            </p>
          {%- endif -%}
        </div>
      {%- else -%}
        <cart-drawer-items>
          <form
            action="{{ routes.cart_url }}"
            id="CartDrawer-Form"
            class="cart__contents cart-drawer__form"
            method="post"
          >
            <div id="CartDrawer-CartItems" class="js-contents ab-cart-list">
              {%- for item in cart.items -%}
                <div
                  id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                  class="ab-cart-item cart-item"
                  role="group"
                >
                  <a href="{{ item.url }}" class="ab-cart-item__media" tabindex="-1" aria-hidden="true">
                    {%- if item.image -%}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="72"
                        height="72"
                      >
                    {%- endif -%}
                  </a>

                  <div class="ab-cart-item__info">
                    <a href="{{ item.url }}" class="ab-cart-item__title cart-item__name break">
                      {{- item.product.title | escape -}}
                    </a>

                    {%- if item.product.description != blank -%}
                      <p class="ab-cart-item__desc">
                        {{- item.product.description | strip_html | truncatewords: 12 -}}
                      </p>
                    {%- endif -%}

                    {%- unless item.product.has_only_default_variant -%}
                      <p class="ab-cart-item__variant">
                        {%- for option in item.options_with_values -%}
                          {{ option.name }}: {{ option.value }}{%- unless forloop.last %} · {% endunless -%}
                        {%- endfor -%}
                      </p>
                    {%- endunless -%}

                    <div class="ab-cart-item__row">
                      <quantity-input class="quantity cart-quantity ab-qty">
                        <button class="quantity__button" name="minus" type="button" aria-label="Decrease quantity">−</button>
                        <input
                          class="quantity__input"
                          type="number"
                          data-quantity-variant-id="{{ item.variant.id }}"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          {% # theme-check-disable %}
                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                          min="0"
                          data-min="{{ item.variant.quantity_rule.min }}"
                          {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                          step="{{ item.variant.quantity_rule.increment }}"
                          {% # theme-check-enable %}
                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                          id="Drawer-quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                        >
                        <button class="quantity__button" name="plus" type="button" aria-label="Increase quantity">+</button>
                      </quantity-input>

                      <div class="ab-cart-item__price">
                        {%- if item.original_line_price != item.final_line_price -%}
                          <s>{{ item.original_line_price | money }}</s>
                          {{ item.final_line_price | money }}
                        {%- else -%}
                          {{ item.original_line_price | money }}
                        {%- endif -%}
                      </div>
                    </div>

                    <div
                      id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                      class="cart-item__error"
                      role="alert"
                    >
                      <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                      <small class="cart-item__error-text"></small>
                    </div>
                  </div>

                  <cart-remove-button
                    id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                    data-index="{{ item.index | plus: 1 }}"
                    class="ab-cart-item__remove"
                  >
                    <button
                      type="button"
                      aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                      data-variant-id="{{ item.variant.id }}"
                    >
                      <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                    </button>
                  </cart-remove-button>

                  {%- render 'loading-spinner' -%}
                </div>
              {%- endfor -%}
            </div>

            <cart-note class="ab-cart-note field">
              <label class="ab-cart-note__label" for="CartDrawer-Note">Add A note to your order</label>
              <textarea
                id="CartDrawer-Note"
                class="ab-cart-note__input text-area"
                name="note"
                placeholder=""
              >{{ cart.note }}</textarea>
            </cart-note>

            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </form>
        </cart-drawer-items>

        {%- assign cart_savings = cart.original_total_price | minus: cart.total_price -%}
        <div class="cart-drawer__footer">
          <div class="ab-totals">
            <div class="ab-totals__row">
              <span>Cart Total</span>
              <span>{{ cart.original_total_price | money }}</span>
            </div>
            <div class="ab-totals__row">
              <span>Your Savings</span>
              <span>{{ cart_savings | money }}</span>
            </div>
          </div>

          <div class="ab-totals__subtotal">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="ab-totals__note">Taxes &amp; Shipping calculated at checkout</p>

          <div class="ab-promo">
            <input
              type="text"
              class="ab-promo__input"
              placeholder="Promocode"
              aria-label="Promocode"
            >
            <button
              type="button"
              class="ab-promo__apply"
              onclick="(function(b){var i=b.parentNode.querySelector('.ab-promo__input');var c=(i.value||'').trim();if(c){window.location.href='/discount/'+encodeURIComponent(c)+'?redirect='+encodeURIComponent(location.pathname);}else{i.focus();}})(this)"
            >APPLY</button>
          </div>

          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="ab-btn ab-btn--checkout"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}disabled{% endif %}
          >
            Check out
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</cart-drawer>
